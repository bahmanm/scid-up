package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures book_window.tcl]

namespace eval ::gui_book_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_book_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::book_window::setup stubbedCommands
}

proc ::gui_book_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::book_window::cleanup stubbedCommands

    catch {unset ::book::isOpen}
    catch {unset ::book::currentBook}
    catch {namespace delete ::book}
}

proc ::gui_book_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list combobox .bookWin.f.combo \
        -width [::scid_test::widgets::getState .bookWin.f.combo -width] \
        -values [::scid_test::widgets::getState .bookWin.f.combo -values] \
        -current [::scid_test::widgets::getState .bookWin.f.combo -current] \
    ]

    foreach t {.bookWin.f.text .bookWin.f.text1} {
        lappend lines [list text $t \
            -wrap [::scid_test::widgets::getState $t -wrap] \
            -state [::scid_test::widgets::getState $t -state] \
            -width [::scid_test::widgets::getState $t -width] \
        ]
    }

    set sequencesByWidget {}
    foreach call [::scid_test::gui_fixtures::book_window::bindCalls] {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    return [join $lines "\n"]
}

test gui-book-window-baseline-compare-1.0 {Book browser window skeleton matches the approved baseline structure} -setup {
    ::gui_book_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows book.tcl]

    ::scid_test::mocks::stubCommand ::gui_book_window_baseline_test::stubbedCommands ::book::bookSelect {args} { return }
    ::scid_test::mocks::stubCommand ::gui_book_window_baseline_test::stubbedCommands ::book::closeMainBook {args} { return }

    ::book::open
    set actual [::gui_book_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] book_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Book browser window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/book_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Book window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_book_window_baseline_test::cleanup
} -result 1

cleanupTests
