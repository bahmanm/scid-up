package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_bookmarks_menu_baseline_test {
    variable stubbedCommands {}
    variable canAdd 1
}

proc ::gui_bookmarks_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_bookmarks_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_bookmarks_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::gui_bookmarks_menu_baseline_test::canAdd 1

    set ::languages {E}
    set ::language E
    set ::langName(E) "English"
    set ::langUnderline(E) 0

    ::scid_test::mocks::stubCommand ::gui_bookmarks_menu_baseline_test::stubbedCommands configMenuText {menu entry tag lang} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_bookmarks_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_bookmarks_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        set w [lindex $args 0]
        switch -- $subcmd {
            parent {
                if {![regexp {^(.+)\.[^.]+$} $w -> parent]} {
                    return "."
                }
                if {$parent eq ""} { return "." }
                return $parent
            }
            children {
                set out {}
                foreach m [namespace eval ::scid_test::menu_capture { variable created; set created }] {
                    if {![llength [info commands $m]]} {
                        continue
                    }
                    if {$m eq $w} {
                        continue
                    }
                    if {[winfo parent $m] eq $w} {
                        lappend out $m
                    }
                }
                return $out
            }
            exists {
                expr {[llength [info commands $w]] > 0}
            }
            default {
                error "winfo $subcmd not stubbed in tests"
            }
        }
    }
}

proc ::gui_bookmarks_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_bookmarks_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
}

test gui-bookmarks-menu-baseline-compare-1.0 {Bookmarks menu matches the approved baseline structure} -setup {
    ::gui_bookmarks_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] file bookmark.tcl]

    ::scid_test::mocks::stubCommand ::gui_bookmarks_menu_baseline_test::stubbedCommands ::bookmarks::CanAdd {} {
        return $::gui_bookmarks_menu_baseline_test::canAdd
    }

    menu .menu.file.bookmarks

    set bookmarks(data) [list \
        [list f "Folder A"] \
        [list g "Game 1"] \
        [list g "Game 2"] \
        [list f "Folder B"] \
        [list g "Game 3"] \
    ]
    set bookmarks(subMenus) 1
    set bookmarks(menuNum) 0

    ::bookmarks::RefreshMenu .menu.file.bookmarks
    set snapshot [::scid_test::menu_structure::snapshot .menu.file.bookmarks]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] bookmarks_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: bookmarks menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/bookmarks_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Bookmarks menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_bookmarks_menu_baseline_test::cleanup
} -result 1

cleanupTests

