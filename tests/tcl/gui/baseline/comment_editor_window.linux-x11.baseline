# ScidUp UI baseline: Comment editor window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/comment_editor_window.test

win::createWindow .commentWin WindowsComment 530x220
text .commentWin.cf.txtframe.text -wrap word -state normal modified 0
comment {sample comment}
nags !!
nagButtons 18
binds {<<Modified>> <Destroy> <KeyPress> <KeyRelease>}
after {idle focus .commentWin.cf.txtframe.text}
