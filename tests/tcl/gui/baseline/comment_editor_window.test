package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures comment_editor_window.tcl]

namespace eval ::gui_comment_editor_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_comment_editor_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::comment_editor_window::setup stubbedCommands
}

proc ::gui_comment_editor_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::comment_editor_window::cleanup stubbedCommands
}

proc ::gui_comment_editor_window_baseline_test::formatSnapshot {} {
    set lines {}
    set w .commentWin

    lappend lines [list win::createWindow {*}[lindex [::scid_test::gui_fixtures::comment_editor_window::winCreateCalls] 0]]

    lappend lines [list text $w.cf.txtframe.text \
        -wrap [::scid_test::widgets::getState $w.cf.txtframe.text -wrap] \
        -state [::scid_test::widgets::getState $w.cf.txtframe.text -state] \
        modified [$w.cf.txtframe.text edit modified] \
    ]

    lappend lines [list comment [::scid_test::widgets::getText $w.cf.txtframe.text]]
    lappend lines [list nags [::scid_test::widgets::getText $w.nf.text]]
    lappend lines [list nagButtons [llength [winfo children $w.nf.b]]]

    set sequences {}
    foreach call [::scid_test::gui_fixtures::comment_editor_window::bindCalls] {
        lappend sequences [lindex $call 1]
    }
    set sequences [lsort -unique $sequences]
    lappend lines [list binds $sequences]

    lappend lines [list after [lindex [::scid_test::gui_fixtures::comment_editor_window::afterCalls] end]]

    return [join $lines "\n"]
}

test gui-comment-editor-window-baseline-compare-1.0 {Comment editor window skeleton matches the approved baseline structure} -setup {
    ::gui_comment_editor_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows comment.tcl]

    ::windows::commenteditor::createWin 1
    set actual [::gui_comment_editor_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] comment_editor_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Comment editor window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/comment_editor_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Comment editor baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_comment_editor_window_baseline_test::cleanup
} -result 1

cleanupTests
