# ScidUp UI baseline: Crosstable window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/crosstab_window.test

text .crosstableWin.f.text -wrap none -font font_Fixed -state normal
menu.format {menu .crosstableWin.menu dynamic 0 entries {
  {type cascade label CrosstabFile acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.file dynamic 0 entries {
      {type command label CrosstabFileText acc {} state normal underline 0 submenu {}}
      {type command label CrosstabFileHtml acc {} state normal underline 0 submenu {}}
      {type command label CrosstabFileLaTeX acc {} state normal underline 0 submenu {}}
      {type separator label {} acc {} state normal underline 0 submenu {}}
      {type command label CrosstabFileClose acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label CrosstabEdit acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.edit dynamic 0 entries {
      {type command label CrosstabEditEvent acc {} state normal underline 0 submenu {}}
      {type command label CrosstabEditSite acc {} state normal underline 0 submenu {}}
      {type command label CrosstabEditDate acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label CrosstabOpt acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.opt dynamic 0 entries {
      {type radiobutton label CrosstabOptAll acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabOptSwiss acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabOptKnockout acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabOptAuto acc {} state normal underline 0 submenu {}}
      {type separator label {} acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptAges acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptNats acc {} state normal underline 0 submenu {}}
      {type checkbutton label Flag acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptRatings acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptTitles acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptBreaks acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptDeleted acc {} state normal underline 0 submenu {}}
      {type separator label {} acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptColors acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptColumnNumbers acc {} state normal underline 0 submenu {}}
      {type separator label {} acc {} state normal underline 0 submenu {}}
      {type checkbutton label CrosstabOptGroup acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label CrosstabSort acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.sort dynamic 0 entries {
      {type radiobutton label CrosstabSortName acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabSortRating acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabSortScore acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label CrosstabText acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.color dynamic 0 entries {
      {type radiobutton label CrosstabColorPlain acc {} state normal underline 0 submenu {}}
      {type radiobutton label CrosstabColorHyper acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label CrosstabHelp acc {} state normal underline 0 submenu {
    menu .crosstableWin.menu.helpmenu dynamic 0 entries {
      {type command label CrosstabHelpCross acc {} state normal underline 0 submenu {}}
      {type command label CrosstabHelpIndex acc {} state normal underline 0 submenu {}}
    }
  }}
}}
binds .crosstableWin.f.text <ButtonPress-1>
