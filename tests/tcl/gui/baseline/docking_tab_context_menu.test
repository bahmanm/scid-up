package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_docking_tab_menu_baseline_test {
    variable stubbedCommands {}
    variable identifiedTab ""

    variable notebookTabs
    array set notebookTabs {}
}

proc ::gui_docking_tab_menu_baseline_test::defineNotebook {path tabs} {
    if {[llength [info commands $path]]} {
        catch {rename $path ""}
    }
    set ::gui_docking_tab_menu_baseline_test::notebookTabs($path) $tabs
    interp alias {} $path {} ::gui_docking_tab_menu_baseline_test::dispatchNotebook $path
    return $path
}

proc ::gui_docking_tab_menu_baseline_test::dispatchNotebook {path subcmd args} {
    switch -- $subcmd {
        identify {
            set op [lindex $args 0]
            if {$op ne "tab"} {
                error "Notebook $path identify $op not stubbed"
            }
            return $::gui_docking_tab_menu_baseline_test::identifiedTab
        }
        tab {
            # Minimal support for `tab <idx> -image` queried by `identify_tab_`.
            set opt [lindex $args 1]
            if {$opt ne "-image"} {
                return ""
            }
            return ""
        }
        tabs {
            return $::gui_docking_tab_menu_baseline_test::notebookTabs($path)
        }
        select { return }
        default { error "Notebook $path subcommand $subcmd not stubbed" }
    }
}

proc ::gui_docking_tab_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_docking_tab_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_docking_tab_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::win {}
    namespace eval ::docking {}

    set ::gui_docking_tab_menu_baseline_test::identifiedTab ""

    ::scid_test::mocks::stubCommand ::gui_docking_tab_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }

    ::scid_test::mocks::stubCommand ::gui_docking_tab_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_docking_tab_menu_baseline_test::stubbedCommands tk_popup {menu x y} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_docking_tab_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

}

proc ::gui_docking_tab_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_docking_tab_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    foreach path [array names ::gui_docking_tab_menu_baseline_test::notebookTabs] {
        catch {rename $path ""}
    }
    catch {unset ::gui_docking_tab_menu_baseline_test::notebookTabs}
    array set ::gui_docking_tab_menu_baseline_test::notebookTabs {}
}

test gui-docking-tab-menu-baseline-compare-1.0 {Docking tab context menu matches the approved baseline structure} -setup {
    ::gui_docking_tab_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] utils win.tcl]

    set noteb .nb
    ::gui_docking_tab_menu_baseline_test::defineNotebook $noteb [list .main .pgnWin]

    set ::gui_docking_tab_menu_baseline_test::identifiedTab 0
    ::docking::manage_rightclick_ $noteb 10 20 1 1
    set mainSnapshot [::scid_test::menu_structure::snapshot .ctxtMenu]
    set mainFormatted [::scid_test::menu_structure::format $mainSnapshot]

    set ::gui_docking_tab_menu_baseline_test::identifiedTab 1
    ::docking::manage_rightclick_ $noteb 10 20 1 1
    set toolSnapshot [::scid_test::menu_structure::snapshot .ctxtMenu]
    set toolFormatted [::scid_test::menu_structure::format $toolSnapshot]

    set actual [join [list \
        "TAB_MAIN" \
        $mainFormatted \
        "TAB_TOOL" \
        $toolFormatted \
    ] "\n"]

    set baselineFile [file join [file dirname [info script]] docking_tab_context_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: docking tab context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/docking_tab_context_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Docking tab menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_docking_tab_menu_baseline_test::cleanup
} -result 1

cleanupTests
