# ScidUp UI baseline: ECO browser window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/eco_browser_window.test

entry .ecograph.title -width 15 -font font_Bold
canvas .ecograph.pane.graph.c -width 500 -height 250 -selectforeground scid_test_foreground
text .ecograph.pane.text.text -width 75 -height 12 -wrap word -state normal
tag bold -font font_Bold
tag indent -lmargin2 20
binds .ecograph {<Configure> <Destroy> <Down> <End> <Escape> <F1> <Home> <KeyPress-0> <KeyPress-1> <KeyPress-2> <KeyPress-3> <KeyPress-4> <KeyPress-5> <KeyPress-6> <KeyPress-7> <KeyPress-8> <KeyPress-9> <KeyPress-A> <KeyPress-B> <KeyPress-BackSpace> <KeyPress-C> <KeyPress-D> <KeyPress-Delete> <KeyPress-E> <KeyPress-Left> <KeyPress-a> <KeyPress-b> <KeyPress-c> <KeyPress-d> <KeyPress-e> <KeyPress-f> <KeyPress-g> <KeyPress-h> <KeyPress-i> <KeyPress-j> <KeyPress-k> <KeyPress-l> <KeyPress-less> <KeyPress-m> <KeyPress-n> <KeyPress-o> <KeyPress-p> <KeyPress-q> <KeyPress-r> <KeyPress-s> <KeyPress-t> <KeyPress-u> <KeyPress-v> <KeyPress-w> <KeyPress-x> <KeyPress-y> <KeyPress-z> <Next> <Prior> <Up>}
binds .ecograph.pane.graph <Configure>
binds .ecograph.pane.graph.c {<1> <3>}
