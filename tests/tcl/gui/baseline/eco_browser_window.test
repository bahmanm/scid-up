package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures eco_browser_window.tcl]

namespace eval ::gui_eco_browser_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_eco_browser_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::eco_browser_window::setup stubbedCommands
}

proc ::gui_eco_browser_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::eco_browser_window::cleanup stubbedCommands
    catch {unset ::windows::eco::isOpen}
    catch {unset ::windows::eco::code}
    catch {unset ::windows::eco::count}
}

proc ::gui_eco_browser_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list entry .ecograph.title \
        -width [::scid_test::widgets::getState .ecograph.title -width] \
        -font [::scid_test::widgets::getState .ecograph.title -font] \
    ]

    lappend lines [list canvas .ecograph.pane.graph.c \
        -width [::scid_test::widgets::getState .ecograph.pane.graph.c -width] \
        -height [::scid_test::widgets::getState .ecograph.pane.graph.c -height] \
        -selectforeground [::scid_test::widgets::getState .ecograph.pane.graph.c -selectforeground] \
    ]

    lappend lines [list text .ecograph.pane.text.text \
        -width [::scid_test::widgets::getState .ecograph.pane.text.text -width] \
        -height [::scid_test::widgets::getState .ecograph.pane.text.text -height] \
        -wrap [::scid_test::widgets::getState .ecograph.pane.text.text -wrap] \
        -state [::scid_test::widgets::getState .ecograph.pane.text.text -state] \
    ]

    set tagCfg [::scid_test::widgets::getTagConfigureCalls .ecograph.pane.text.text]
    foreach {tag opt} {bold -font indent -lmargin2} {
        set val ""
        foreach call $tagCfg {
            if {[lindex $call 0] ne $tag} { continue }
            set idx [lsearch -exact $call $opt]
            if {$idx >= 0} {
                set val [lindex $call [expr {$idx + 1}]]
            }
            break
        }
        lappend lines [list tag $tag $opt $val]
    }

    set sequencesByWidget {}
    foreach call [::scid_test::gui_fixtures::eco_browser_window::bindCalls] {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    return [join $lines "\n"]
}

test gui-eco-browser-window-baseline-compare-1.0 {ECO browser window skeleton matches the approved baseline structure} -setup {
    ::gui_eco_browser_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows eco.tcl]
    ::scid_test::mocks::stubCommand ::gui_eco_browser_window_baseline_test::stubbedCommands ::windows::eco::update {args} {
        return
    }

    ::windows::eco::Refresh
    set actual [::gui_eco_browser_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] eco_browser_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: ECO browser window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/eco_browser_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "ECO browser window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_eco_browser_window_baseline_test::cleanup
} -result 1

cleanupTests
