package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures engine_window.tcl]

namespace eval ::gui_engine_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_engine_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::engine_window::setup stubbedCommands
}

proc ::gui_engine_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::engine_window::cleanup stubbedCommands

    catch {namespace delete ::enginewin}
    unset -nocomplain ::enginewin::engState
    unset -nocomplain ::enginewin_lastengine
}

proc ::gui_engine_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list text .engineWin1.display.pv_lines \
        -tabs [::scid_test::widgets::getState .engineWin1.display.pv_lines -tabs] \
    ]

    set tagCfg [::scid_test::widgets::getTagConfigureCalls .engineWin1.display.pv_lines]
    foreach {tag opt} {lmargin -lmargin2 markmove -underline} {
        set val ""
        foreach call $tagCfg {
            if {[lindex $call 0] ne $tag} { continue }
            set idx [lsearch -exact $call $opt]
            if {$idx >= 0} {
                set val [lindex $call [expr {$idx + 1}]]
            }
            break
        }
        lappend lines [list tag $tag $opt $val]
    }

    set tagBindPairs {}
    foreach call [::scid_test::widgets::getTagBindCalls .engineWin1.display.pv_lines] {
        lappend tagBindPairs [list [lindex $call 0] [lindex $call 1]]
    }
    lappend lines [list tagbinds [lsort -unique $tagBindPairs]]

    set sequencesByWidget {}
    foreach call [::scid_test::gui_fixtures::engine_window::bindCalls] {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    return [join $lines "\n"]
}

test gui-engine-window-baseline-compare-1.0 {Engine window skeleton matches the approved baseline structure} -setup {
    ::gui_engine_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows engine.tcl]

    ::scid_test::mocks::stubCommand ::gui_engine_window_baseline_test::stubbedCommands ::enginewin::createButtonsBar {args} { return }
    ::scid_test::mocks::stubCommand ::gui_engine_window_baseline_test::stubbedCommands ::enginewin::connectEngine {args} { return }

    ::enginewin::Open
    set actual [::gui_engine_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] engine_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Engine window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/engine_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Engine window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_engine_window_baseline_test::cleanup
} -result 1

cleanupTests

