package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_file_finder_context_menu_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_file_finder_context_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_file_finder_context_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::file {}
    namespace eval ::file::finder {}

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_baseline_test::stubbedCommands update {args} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            pointerx { return 100 }
            pointery { return 200 }
            default {
                error "winfo $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }
}

proc ::gui_file_finder_context_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
}

test gui-file-finder-context-menu-baseline-compare-1.0 {File Finder context menu matches the approved baseline structure} -setup {
    ::gui_file_finder_context_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] file finder.tcl]

    set win .finder.t.text
    set fullPath [file join [pwd] "example.si4"]
    ::file::finder::contextMenu $win $fullPath 1 2 101 202

    set snapshot [::scid_test::menu_structure::snapshot ${win}.ctxtMenu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] file_finder_context_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: File Finder context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/file_finder_context_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "File Finder context menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_file_finder_context_menu_baseline_test::cleanup
} -result 1

cleanupTests

