package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_file_finder_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_file_finder_window_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_file_finder_window_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 0

    set ::windowsOS 0
    set ::language E

    array set ::tr {
        FileFinder FileFinder
        FinderSortType FinderSortType
        FinderTypesScid FinderTypesScid
        FinderTypesOld FinderTypesOld
        FinderTypesPGN FinderTypesPGN
        FinderTypesRep FinderTypesRep
        FinderTypesEPD FinderTypesEPD
        Stop Stop
        FinderFileSubdirs FinderFileSubdirs
        FinderDir FinderDir
    }

    array set ::menuLabel {
        E,FinderSortType FinderSortType
        E,FinderTypesScid FinderTypesScid
        E,FinderTypesOld FinderTypesOld
        E,FinderTypesPGN FinderTypesPGN
        E,FinderTypesRep FinderTypesRep
        E,FinderTypesEPD FinderTypesEPD
    }

    namespace eval ::file {}
    namespace eval ::file::finder {}
    namespace eval ::win {}
    namespace eval ::utils {}
    namespace eval ::utils::tooltip {}

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands tr {tag {lang ""}} {
        if {[info exists ::tr($tag)]} { return $::tr($tag) }
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands wm {subcmd args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands bind {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands pack {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands grid {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands update {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands busyCursor {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands unbusyCursor {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands setWinLocation {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands recordWinSize {args} { return }
    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands ::utils::tooltip::Set {w msg} { return }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    foreach cmd {frame labelframe checkbutton button label menubutton} {
        ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands ::ttk::$cmd {path args} {
            if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
            if {[llength $args]} { $path configure {*}$args }
            return $path
        }
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands ::win::createDialog {w} {
        if {![llength [info commands $w]]} { ::scid_test::widgets::defineWidget $w }
        return
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands tk_optionMenu {path varName args} {
        set menuPath "${path}.menu"
        if {![llength [info commands $menuPath]]} {
            menu $menuPath
        }
        return $menuPath
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands autoscrollText {bars frame widget style} {
        if {![llength [info commands $frame]]} { ::scid_test::widgets::defineWidget $frame }
        if {![llength [info commands $widget]]} { ::scid_test::widgets::defineTextWidget $widget }
        return
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands font {subcmd args} {
        if {$subcmd ne "measure"} { return "scid_test_font" }
        return 8
    }
}

proc ::gui_file_finder_window_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
    unset -nocomplain ::menuLabel
    unset -nocomplain ::windowsOS
    unset -nocomplain ::language
}

proc ::gui_file_finder_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list widget .finder.t.text \
        -width [::scid_test::widgets::getState .finder.t.text -width] \
        -height [::scid_test::widgets::getState .finder.t.text -height] \
        -wrap [::scid_test::widgets::getState .finder.t.text -wrap] \
        -setgrid [::scid_test::widgets::getState .finder.t.text -setgrid] \
        -cursor [::scid_test::widgets::getState .finder.t.text -cursor] \
    ]

    foreach tag {Dir Vol PGN Scid Old Rep EPD bold center} {
        set cfg [::scid_test::widgets::getTagConfigureCalls .finder.t.text]
        set found 0
        foreach call $cfg {
            if {[lindex $call 0] eq $tag} {
                set found 1
                break
            }
        }
        lappend lines [list tag $tag configured $found]
    }

    return [join $lines "\n"]
}

test gui-file-finder-window-baseline-compare-1.0 {File Finder window skeleton matches the approved baseline structure} -setup {
    ::gui_file_finder_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] file finder.tcl]

    ::scid_test::mocks::stubCommand ::gui_file_finder_window_baseline_test::stubbedCommands ::file::finder::Refresh {args} {
        return
    }

    ::file::finder::Open
    set actual [::gui_file_finder_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] file_finder_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: File Finder window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/file_finder_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "File Finder window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_file_finder_window_baseline_test::cleanup
} -result 1

cleanupTests
