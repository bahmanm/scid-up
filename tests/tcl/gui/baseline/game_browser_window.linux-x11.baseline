# ScidUp UI baseline: Game browser window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/game_browser_window.test

text .gb0.t.text -wrap word -state disabled -width 45 -height 12 -font font_Small -setgrid 1
board.update.calls {{.gb0.bd b0 1}}
tagbinds {{m0 <Any-Enter>} {m0 <Any-Leave>} {m0 <ButtonRelease-1>} {m1 <Any-Enter>} {m1 <Any-Leave>} {m1 <ButtonRelease-1>} {m2 <Any-Enter>} {m2 <Any-Leave>} {m2 <ButtonRelease-1>}}
binds .gb0 {<Control-Shift-Left> <Control-Shift-Right> <Down> <End> <Escape> <F1> <Home> <Left> <Right> <Up> <minus> <plus>}
mousewheel {{.gb0 {::gbrowser::mousewheelHandler 0}}}
