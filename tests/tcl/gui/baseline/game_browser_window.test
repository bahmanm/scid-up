package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures game_browser_window.tcl]

namespace eval ::gui_game_browser_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_game_browser_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::game_browser_window::setup stubbedCommands
}

proc ::gui_game_browser_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::game_browser_window::cleanup stubbedCommands
    catch {namespace delete ::gbrowser}
}

proc ::gui_game_browser_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list text .gb0.t.text \
        -wrap [::scid_test::widgets::getState .gb0.t.text -wrap] \
        -state [::scid_test::widgets::getState .gb0.t.text -state] \
        -width [::scid_test::widgets::getState .gb0.t.text -width] \
        -height [::scid_test::widgets::getState .gb0.t.text -height] \
        -font [::scid_test::widgets::getState .gb0.t.text -font] \
        -setgrid [::scid_test::widgets::getState .gb0.t.text -setgrid] \
    ]

    lappend lines [list board.update.calls [::scid_test::gui_fixtures::game_browser_window::boardUpdateCalls]]

    set tagBindPairs {}
    foreach call [::scid_test::widgets::getTagBindCalls .gb0.t.text] {
        lappend tagBindPairs [list [lindex $call 0] [lindex $call 1]]
    }
    lappend lines [list tagbinds [lsort -unique $tagBindPairs]]

    set sequencesByWidget {}
    foreach call [::scid_test::gui_fixtures::game_browser_window::bindCalls] {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    lappend lines [list mousewheel [::scid_test::gui_fixtures::game_browser_window::mouseWheelBindings]]

    return [join $lines "\n"]
}

test gui-game-browser-window-baseline-compare-1.0 {Game browser window skeleton matches the approved baseline structure} -setup {
    ::gui_game_browser_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows browser.tcl]

    ::gbrowser::new 1 7
    set actual [::gui_game_browser_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] game_browser_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Game browser window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/game_browser_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game browser window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_game_browser_window_baseline_test::cleanup
} -result 1

cleanupTests
