package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_game_info_menu_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_game_info_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_menu_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_game_info_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::MB3 3
    set ::macOS 0

    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        return
    }

    set _photosRoot [::scid_test::tempDir]
    foreach dirVar {::scidDataDir ::scidUserDir ::scidConfigDir ::scidShareDir} {
        set $dirVar $_photosRoot
    }
    file mkdir [file join $::scidShareDir photos]
    unset _photosRoot

    namespace eval ::htext {}
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands ::htext::init {w} {
        return
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands ::ttk::label {path args} {
        if {![llength [info commands $path]]} {
            ::scid_test::widgets::defineWidget $path
        }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands autoscrollText {axis frame textWidget class} {
        if {![llength [info commands $textWidget]]} {
            ::scid_test::widgets::defineTextWidget $textWidget
        }
        return
    }

    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_baseline_test::stubbedCommands translateMenuLabels {menu} {
        return
    }
}

proc ::gui_game_info_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_menu_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::MB3
}

test gui-game-info-menu-baseline-compare-1.0 {Game-info context menu matches the approved baseline structure} -setup {
    ::gui_game_info_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    CreateGameInfo
    set snapshot [::scid_test::menu_structure::snapshot .main.gameInfo.menu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] game_info_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: game-info context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/game_info_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game-info menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_game_info_menu_baseline_test::cleanup
} -result 1

cleanupTests

