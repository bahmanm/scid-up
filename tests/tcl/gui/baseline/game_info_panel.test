package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_game_info_panel_baseline_test {
    variable stubbedCommands {}
    variable tempRoot ""
}

proc ::gui_game_info_panel_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_panel_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_game_info_panel_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::MB3 3
    set ::macOS 0

    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        return
    }

    set ::gui_game_info_panel_baseline_test::tempRoot [::scid_test::makeTempRoot [namespace current]]
    set _photosRoot $::gui_game_info_panel_baseline_test::tempRoot
    foreach dirVar {::scidDataDir ::scidUserDir ::scidConfigDir ::scidShareDir} {
        set $dirVar $_photosRoot
    }
    file mkdir [file join $::scidShareDir photos]
    unset _photosRoot

    namespace eval ::htext {}
    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands ::htext::init {w} {
        return
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands ::ttk::label {path args} {
        if {![llength [info commands $path]]} {
            ::scid_test::widgets::defineWidget $path
        }
        if {[llength $args]} {
            $path configure {*}$args
        }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands autoscrollText {axis frame textWidget class} {
        if {![llength [info commands $textWidget]]} {
            ::scid_test::widgets::defineTextWidget $textWidget
        }
        return
    }

    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }
    ::scid_test::mocks::stubCommand ::gui_game_info_panel_baseline_test::stubbedCommands translateMenuLabels {menu} {
        return
    }
}

proc ::gui_game_info_panel_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_panel_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::deleteTempRoot $::gui_game_info_panel_baseline_test::tempRoot
    set ::gui_game_info_panel_baseline_test::tempRoot ""

    unset -nocomplain ::MB3
}

proc ::gui_game_info_panel_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list widget .main.gameInfo.text \
        -width [::scid_test::widgets::getState .main.gameInfo.text -width] \
        -height [::scid_test::widgets::getState .main.gameInfo.text -height] \
        -wrap [::scid_test::widgets::getState .main.gameInfo.text -wrap] \
        -state [::scid_test::widgets::getState .main.gameInfo.text -state] \
        -cursor [::scid_test::widgets::getState .main.gameInfo.text -cursor] \
    ]

    foreach label {.main.photoW .main.photoB} imageName {photoW photoB} {
        lappend lines [list widget $label \
            -image [::scid_test::widgets::getState $label -image] \
            -anchor [::scid_test::widgets::getState $label -anchor] \
        ]
    }

    return [join $lines "\n"]
}

test gui-game-info-panel-baseline-compare-1.0 {Game-info panel widget skeleton matches the approved baseline structure} -setup {
    ::gui_game_info_panel_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    CreateGameInfo
    set actual [::gui_game_info_panel_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] game_info_panel.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: game-info panel widget skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/game_info_panel.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game-info panel baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_game_info_panel_baseline_test::cleanup
} -result 1

cleanupTests

