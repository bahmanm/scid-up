package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_game_load_menu_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_game_load_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_load_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_game_load_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::game {}

    array set ::tr {
        BrowseGame BrowseGame
        LoadGame LoadGame
        MergeGame MergeGame
    }

    ::scid_test::mocks::stubCommand ::gui_game_load_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }

    ::scid_test::mocks::stubCommand ::gui_game_load_menu_baseline_test::stubbedCommands event {subcmd args} {
        if {$subcmd ne "generate"} {
            error "event $subcmd not stubbed in tests"
        }
        return
    }
}

proc ::gui_game_load_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_load_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
    unset -nocomplain ::tr
}

test gui-game-load-menu-baseline-compare-1.0 {Game load menu matches the approved baseline structure} -setup {
    ::gui_game_load_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] game.tcl]

    set w .glist
    set base 1
    set gnum 42
    ::game::LoadMenu $w $base $gnum 10 20

    set snapshot [::scid_test::menu_structure::snapshot ${w}.gLoadMenu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] game_load_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: game load menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/game_load_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game load menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_game_load_menu_baseline_test::cleanup
} -result 1

cleanupTests

