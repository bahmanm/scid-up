package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_gamelist_header_menu_baseline_test {
    variable stubbedCommands {}
    variable treeColumnId
    variable treeColumnAnchor
    variable popupCalls {}
    variable removeColCalls {}
    variable sortCalls {}
    array set treeColumnId {}
    array set treeColumnAnchor {}
}

proc ::gui_gamelist_header_menu_baseline_test::defineTreeview {path columnIdByColumnToken} {
    catch {rename $path ""}
    array unset ::gui_gamelist_header_menu_baseline_test::treeColumnId "$path,*"
    array unset ::gui_gamelist_header_menu_baseline_test::treeColumnAnchor "$path,*"
    foreach {colToken colId} $columnIdByColumnToken {
        set ::gui_gamelist_header_menu_baseline_test::treeColumnId($path,$colToken) $colId
        set ::gui_gamelist_header_menu_baseline_test::treeColumnAnchor($path,$colToken) w
    }
    interp alias {} $path {} ::gui_gamelist_header_menu_baseline_test::dispatchTreeview $path
    return $path
}

proc ::gui_gamelist_header_menu_baseline_test::dispatchTreeview {path subcmd args} {
    switch -- $subcmd {
        identify {
            set what [lindex $args 0]
            switch -- $what {
                region { return "heading" }
                column { return "#1" }
                default { error "treeview identify $what not stubbed" }
            }
        }
        column {
            set colToken [lindex $args 0]
            set opt [lindex $args 1]
            if {$opt ni {"-id" "-anchor"}} {
                error "treeview column $opt not stubbed"
            }
            if {![info exists ::gui_gamelist_header_menu_baseline_test::treeColumnId($path,$colToken)]} {
                error "treeview $path missing column id for $colToken"
            }
            if {$opt eq "-id"} {
                return $::gui_gamelist_header_menu_baseline_test::treeColumnId($path,$colToken)
            }
            if {[llength $args] == 2} {
                return $::gui_gamelist_header_menu_baseline_test::treeColumnAnchor($path,$colToken)
            }
            set value [lindex $args 2]
            set ::gui_gamelist_header_menu_baseline_test::treeColumnAnchor($path,$colToken) $value
            return
        }
        default {
            error "treeview $path subcommand $subcmd not stubbed"
        }
    }
}

proc ::gui_gamelist_header_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_header_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
    set ::gui_gamelist_header_menu_baseline_test::popupCalls {}
    set ::gui_gamelist_header_menu_baseline_test::removeColCalls {}
    set ::gui_gamelist_header_menu_baseline_test::sortCalls {}

    ::scid_test::menu_capture::install ::gui_gamelist_header_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::windows {}
    namespace eval ::windows::gamelist {}

    array set ::tr {
        GlistAlignL GlistAlignL
        GlistAlignR GlistAlignR
        GlistAlignC GlistAlignC
        GlistAddField GlistAddField
        GlistDeleteField GlistDeleteField
        ResetSort ResetSort
        FindBar FindBar
        Save Save
        Defaults Defaults
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            parent { return ".glistWin1" }
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            default { error "winfo $subcmd not stubbed in tests" }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands tk_popup {menu x y} {
        lappend ::gui_gamelist_header_menu_baseline_test::popupCalls [list $menu $x $y]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ni {"photo" "bitmap"}} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }
}

proc ::gui_gamelist_header_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_header_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    foreach path [array names ::gui_gamelist_header_menu_baseline_test::treeColumnId] {
        set tree [lindex [split $path ","] 0]
        catch {rename $tree ""}
    }
    array unset ::gui_gamelist_header_menu_baseline_test::treeColumnId
    array set ::gui_gamelist_header_menu_baseline_test::treeColumnId {}
    array unset ::gui_gamelist_header_menu_baseline_test::treeColumnAnchor
    array set ::gui_gamelist_header_menu_baseline_test::treeColumnAnchor {}

    unset -nocomplain ::tr
}

proc ::gui_gamelist_header_menu_baseline_test::installRuntimeStubs {} {
    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands glist.removecol_ {w layout col} {
        lappend ::gui_gamelist_header_menu_baseline_test::removeColCalls [list $w $layout $col]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_baseline_test::stubbedCommands glist.sort_ {w idx layout clear} {
        lappend ::gui_gamelist_header_menu_baseline_test::sortCalls [list $w $idx $layout $clear]
        return
    }
}

proc ::gui_gamelist_header_menu_baseline_test::invokeMenuLabel {menuPath label} {
    foreach entry [::scid_test::menu_capture::entries $menuPath] {
        if {[dict get $entry -label] eq $label} {
            uplevel #0 [dict get $entry -command]
            return
        }
    }
    error "Menu $menuPath has no entry labelled: $label"
}

test gui-gamelist-header-menu-baseline-compare-1.0 {Game list header menu matches the approved baseline structure} -setup {
    ::gui_gamelist_header_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_baseline_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_baseline_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0

    glist.popupmenu_ $w 1 1 100 200 $layout

    set snapshot [::scid_test::menu_structure::snapshot ${w}.header_menu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] gamelist_header_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: game list header context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/gamelist_header_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game list header menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_gamelist_header_menu_baseline_test::cleanup
} -result 1

test gui-gamelist-header-menu-actions-baseline-compare-1.0 {Game list header menu actions match the approved baseline} -setup {
    ::gui_gamelist_header_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_baseline_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_baseline_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0

    glist.popupmenu_ $w 1 1 100 200 $layout

    ::gui_gamelist_header_menu_baseline_test::invokeMenuLabel ${w}.header_menu GlistAlignR
    ::gui_gamelist_header_menu_baseline_test::invokeMenuLabel ${w}.header_menu GlistDeleteField
    ::gui_gamelist_header_menu_baseline_test::invokeMenuLabel ${w}.header_menu ResetSort

    set lines {}
    lappend lines [list popup.calls $::gui_gamelist_header_menu_baseline_test::popupCalls]
    lappend lines [list column.anchor [$w column #1 -anchor]]
    lappend lines [list layout.anchor [lindex $::glist_ColAnchor($layout) 0]]
    lappend lines [list removecol.calls $::gui_gamelist_header_menu_baseline_test::removeColCalls]
    lappend lines [list sort.calls $::gui_gamelist_header_menu_baseline_test::sortCalls]
    set actual [join $lines "\n"]

    set baselineFile [file join [file dirname [info script]] gamelist_header_menu_actions.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: game list header context menu actions (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/gamelist_header_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game list header menu actions baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_gamelist_header_menu_baseline_test::cleanup
} -result 1

cleanupTests
