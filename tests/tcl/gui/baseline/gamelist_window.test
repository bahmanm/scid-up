    ::windows::gamelist::menu_ .glistWin1 filter
    ::windows::gamelist::menu_ .glistWin1 filter
    ::windows::gamelist::menu_ .glistWin1 stats

    ::windows::gamelist::filter_ .glistWin1 r
    ::windows::gamelist::filter_ .glistWin1 b
    ::windows::gamelist::filter_ .glistWin1 h
    ::windows::gamelist::filter_ .glistWin1 m
