    lappend lines [list search.material.calls [::scid_test::gui_fixtures::gamelist_window::searchMaterialCalls]]
    lappend lines [list filter.negate.calls [::scid_test::gui_fixtures::gamelist_window::filterNegateCalls]]
    lappend lines [list notify.filter.calls [::scid_test::gui_fixtures::gamelist_window::notifyFilterCalls]]
