test gui-gamelist-window-export-baseline-compare-1.0 {Game list window export actions match the approved baseline} -setup {
    ::gui_gamelist_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_baseline_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    set ::glistSortStr(.glistWin1.games.glist) W+

    set lines {}

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    lappend lines [list pgn.save.calls [::scid_test::gui_fixtures::gamelist_window::saveFileCalls]]
    lappend lines [list pgn.progress.calls [::scid_test::gui_fixtures::gamelist_window::progressCalls]]
    lappend lines [list pgn.export.calls [::scid_test::gui_fixtures::gamelist_window::filterExportCalls]]
    lappend lines [list pgn.progress.close [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls]]
    lappend lines [list pgn.errorbox.calls [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]

    set ::gamelistExport LaTeX
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export-tex
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    lappend lines [list latex.save.calls [::scid_test::gui_fixtures::gamelist_window::saveFileCalls]]
    lappend lines [list latex.progress.calls [::scid_test::gui_fixtures::gamelist_window::progressCalls]]
    lappend lines [list latex.export.calls [::scid_test::gui_fixtures::gamelist_window::filterExportCalls]]
    lappend lines [list latex.progress.close [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls]]
    lappend lines [list latex.errorbox.calls [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse ""
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    lappend lines [list cancel.save.calls [::scid_test::gui_fixtures::gamelist_window::saveFileCalls]]
    lappend lines [list cancel.progress.calls [::scid_test::gui_fixtures::gamelist_window::progressCalls]]
    lappend lines [list cancel.export.calls [::scid_test::gui_fixtures::gamelist_window::filterExportCalls]]
    lappend lines [list cancel.progress.close [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls]]

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export-error
    ::scid_test::gui_fixtures::gamelist_window::setExportError export-failed NOT_USER_CANCEL
    ::windows::gamelist::FilterExport .glistWin1
    lappend lines [list error.export.calls [::scid_test::gui_fixtures::gamelist_window::filterExportCalls]]
    lappend lines [list error.progress.close [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls]]
    lappend lines [list error.errorbox.calls [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]
    set actual [join $lines "\n"]

    set baselineFile [file join [file dirname [info script]] gamelist_window_export.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Game list window export actions (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/gamelist_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Game list window export baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_gamelist_window_baseline_test::cleanup
} -result 1

cleanupTests
