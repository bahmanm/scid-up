test gui-gamelist-window-refresh-baseline-compare-1.0 {Game list window refresh and base-switch actions match the approved baseline} -setup {
    ::gui_gamelist_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_baseline_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    ::windows::gamelist::Open 2 dbfilter
    ::scid_test::gui_fixtures::gamelist_window::installRefreshRuntimeStubs ::gui_gamelist_window_baseline_test::stubbedCommands

    set ::gamelistFilter(.glistWin1) dbfilter+tree
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls

    ::windows::gamelist::DatabaseModified 1
    ::windows::gamelist::DatabaseModified 1 tree
    ::windows::gamelist::DatabaseModified 2 dbfilter
    ::windows::gamelist::DatabaseModified 2 other

    set lines {}
    lappend lines [list dbmod.glist.update.calls [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls]]
    lappend lines [list dbmod.title.calls [::scid_test::gui_fixtures::gamelist_window::titleCalls]]
    lappend lines [list dbmod.updateStats.calls [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls]]

    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls
    ::windows::gamelist::SetBase .glistWin1 2 newfilter
    lappend lines [list setbase.normal.after [::scid_test::gui_fixtures::gamelist_window::afterCalls]]
    lappend lines [list setbase.normal.base $::gamelistBase(.glistWin1)]
    lappend lines [list setbase.normal.filter $::gamelistFilter(.glistWin1)]
    lappend lines [list setbase.normal.glist.update.calls [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls]]
    lappend lines [list setbase.normal.title.calls [::scid_test::gui_fixtures::gamelist_window::titleCalls]]
    lappend lines [list setbase.normal.updateStats.calls [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls]]

    set ::gamelistMenu(.glistWin1) stats
    set ::gamelistPosMask(.glistWin1) 1
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls
    ::windows::gamelist::SetBase .glistWin1 3 dbfilter+tree

    lappend lines [list setbase.posmask.after [::scid_test::gui_fixtures::gamelist_window::afterCalls]]
    lappend lines [list setbase.posmask.base $::gamelistBase(.glistWin1)]
    lappend lines [list setbase.posmask.filter $::gamelistFilter(.glistWin1)]
    lappend lines [list setbase.posmask.enabled $::gamelistPosMask(.glistWin1)]
    lappend lines [list setbase.posmask.menu $::gamelistMenu(.glistWin1)]
    lappend lines [list setbase.posmask.glist.update.calls [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls]]
    lappend lines [list setbase.posmask.updateStats.calls [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls]]
    lappend lines [list setbase.posmask.updateTreeFilter.calls [::scid_test::gui_fixtures::gamelist_window::updateTreeFilterCalls]]
    lappend lines [list setbase.posmask.cancelUpdateTreeFilter.calls [::scid_test::gui_fixtures::gamelist_window::cancelUpdateTreeFilterCalls]]
    lappend lines [list setbase.posmask.notify.filter.calls [::scid_test::gui_fixtures::gamelist_window::notifyFilterCalls]]
    lappend lines [list setbase.posmask.boardFilter.states [::scid_test::widgets::getState .glistWin1.buttons.boardFilter widget.states]]
    set actual [join $lines "\n"]

    set baselineFile [file join [file dirname [info script]] gamelist_window_refresh.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
