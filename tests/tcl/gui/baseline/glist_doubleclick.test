package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_doubleclick_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_doubleclick_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_doubleclick_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_doubleclick_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_doubleclick_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistBase(.glistShell.glist) 1
    set ::glistFilter(.glistShell.glist) dbfilter
    set ::glistSortStr(.glistShell.glist) sortkey

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 1 1 heading
    glist.doubleclick_ .glistShell.glist 1 1 TestLayout
    lappend lines [list heading.delflag.calls [::scid_test::gui_fixtures::glist_widget::delflagCalls]]
    lappend lines [list heading.remove.calls [::scid_test::gui_fixtures::glist_widget::filterRemoveCalls]]
    lappend lines [list heading.load.calls [::scid_test::gui_fixtures::glist_widget::loadCalls]]

    set ::glistClickOp(.glistShell.glist) 1
    ::scid_test::gui_fixtures::glist_widget::setTreeviewSelection .glistShell.glist 9_0
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 2 2 cell
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyItem .glistShell.glist 2 2 9_0
    glist.doubleclick_ .glistShell.glist 2 2 TestLayout
    lappend lines [list delete.delflag.calls [::scid_test::gui_fixtures::glist_widget::delflagCalls]]
    lappend lines [list delete.selection [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    set ::glistClickOp(.glistShell.glist) 2
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyItem .glistShell.glist 3 3 14_7
    glist.doubleclick_ .glistShell.glist 3 3 TestLayout
    lappend lines [list remove.filter.calls [::scid_test::gui_fixtures::glist_widget::filterRemoveCalls]]
    lappend lines [list remove.notify.calls [::scid_test::gui_fixtures::glist_widget::notifyFilterCalls]]

    set ::glistClickOp(.glistShell.glist) 0
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyItem .glistShell.glist 4 4 21_3
    glist.doubleclick_ .glistShell.glist 4 4 TestLayout
    lappend lines [list load.switch.calls [::scid_test::gui_fixtures::glist_widget::switchBaseCalls]]
    lappend lines [list load.calls [::scid_test::gui_fixtures::glist_widget::loadCalls]]

    return [join $lines "\n"]
}

test gui-glist-doubleclick-baseline-compare-1.0 {glist.doubleclick_ matches the approved baseline} -setup {
    ::gui_glist_doubleclick_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_doubleclick_baseline_test::stubbedCommands
    ::gui_glist_doubleclick_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_doubleclick_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_doubleclick.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.doubleclick_ (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_doubleclick.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.doubleclick_ baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_doubleclick_baseline_test::cleanup
} -result 1

cleanupTests
