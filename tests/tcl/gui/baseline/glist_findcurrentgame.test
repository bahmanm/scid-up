package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_findcurrent_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_findcurrent_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_findcurrent_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_findcurrent_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_findcurrent_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistBase(.glistShell.glist) 1
    set ::glistFilter(.glistShell.glist) dbfilter
    set ::glistSortStr(.glistShell.glist) sortkey
    set ::glistFirst(.glistShell.glist) 2

    ::scid_test::gui_fixtures::glist_widget::setGamelocationResponse 1 dbfilter sortkey 42 17
    glist.findcurrentgame_ .glistShell.glist 42
    lappend lines [list first.after.found $::glistFirst(.glistShell.glist)]
    lappend lines [list ybar.after.found [::scid_test::gui_fixtures::glist_widget::ybarCalls]]

    ::scid_test::gui_fixtures::glist_widget::setGamelocationResponse 1 dbfilter sortkey 88 none
    glist.findcurrentgame_ .glistShell.glist 88
    lappend lines [list gamelocation.calls [::scid_test::gui_fixtures::glist_widget::gamelocationCalls]]
    lappend lines [list first.after.miss $::glistFirst(.glistShell.glist)]
    lappend lines [list ybar.after.miss [::scid_test::gui_fixtures::glist_widget::ybarCalls]]

    return [join $lines "\n"]
}

test gui-glist-findcurrent-baseline-compare-1.0 {glist.findcurrentgame_ matches the approved baseline} -setup {
    ::gui_glist_findcurrent_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_findcurrent_baseline_test::stubbedCommands
    ::gui_glist_findcurrent_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_findcurrent_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_findcurrentgame.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.findcurrentgame_ (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_findcurrentgame.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.findcurrentgame_ baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_findcurrent_baseline_test::cleanup
} -result 1

cleanupTests
