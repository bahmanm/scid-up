package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_press_release_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_press_release_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_press_release_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_press_release_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_press_release_baseline_test::formatSnapshot {} {
    set lines {}

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 10 3 separator
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 9 3 #2
    glist.press_ .glistShell.glist 10 3
    lappend lines [list resize.press.mode $::glist_pressMode(.glistShell.glist)]
    lappend lines [list resize.press.column $::glist_resizeColumn(.glistShell.glist)]
    glist.release_ .glistShell.glist 10 3 0 TestLayout
    lappend lines [list resize.after.calls [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    set resizeCallback [lindex [lindex [::scid_test::gui_fixtures::glist_widget::afterCalls] end] 1]
    set resizedId [.glistShell.glist column #2 -id]
    .glistShell.glist column $resizedId -width 77
    uplevel #0 $resizeCallback
    lappend lines [list resize.persisted.id $resizedId]
    lappend lines [list resize.persisted.width [lindex $::glist_ColWidth(TestLayout) [lsearch -exact $::glist_Headers $resizedId]]]
    lappend lines [list resize.globals.cleared [list \
        [info exists ::glist_pressMode(.glistShell.glist)] \
        [info exists ::glist_resizeColumn(.glistShell.glist)] \
        [info exists ::glist_activeHeading(.glistShell.glist)]]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 20 4 heading
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 30 4 heading
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 20 4 #1
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 30 4 #3
    glist.press_ .glistShell.glist 20 4
    glist.release_ .glistShell.glist 30 4 0 TestLayout
    lappend lines [list reorder.displaycolumns [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist -displaycolumns]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyRegion .glistShell.glist 40 5 heading
    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 40 5 #2
    glist.press_ .glistShell.glist 40 5
    glist.release_ .glistShell.glist 40 5 5 TestLayout
    lappend lines [list sort.click.calls [::scid_test::gui_fixtures::glist_widget::sortClickCalls]]

    return [join $lines "\n"]
}

test gui-glist-press-release-baseline-compare-1.0 {glist.press_ and glist.release_ match the approved baseline} -setup {
    ::gui_glist_press_release_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_press_release_baseline_test::stubbedCommands
    ::gui_glist_press_release_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_press_release_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_press_release.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.press_ / glist.release_ (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_press_release.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.press_/glist.release_ baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_press_release_baseline_test::cleanup
} -result 1

cleanupTests
