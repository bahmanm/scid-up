package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_removefilter_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_removefilter_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_removefilter_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_removefilter_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_removefilter_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistBase(.glistShell.glist) 1
    set ::glistFilter(.glistShell.glist) dbfilter
    set ::glistSortStr(.glistShell.glist) sortkey

    ::scid_test::gui_fixtures::glist_widget::setFilterComponents 1 dbfilter {rootfilter auxfilter}
    glist.removeFromFilter_ .glistShell.glist 42
    lappend lines [list ybar.after.plain [::scid_test::gui_fixtures::glist_widget::ybarCalls]]

    ::scid_test::gui_fixtures::glist_widget::setFilterComponents 1 dbfilter {treefilter extra}
    glist.removeFromFilter_ .glistShell.glist 51 +
    lappend lines [list remove.calls [::scid_test::gui_fixtures::glist_widget::filterRemoveCalls]]
    lappend lines [list notify.calls [::scid_test::gui_fixtures::glist_widget::notifyFilterCalls]]
    lappend lines [list ybar.after.plus [::scid_test::gui_fixtures::glist_widget::ybarCalls]]

    return [join $lines "\n"]
}

test gui-glist-removefilter-baseline-compare-1.0 {glist.removeFromFilter_ matches the approved baseline} -setup {
    ::gui_glist_removefilter_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_removefilter_baseline_test::stubbedCommands
    ::gui_glist_removefilter_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_removefilter_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_removefilter.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.removeFromFilter_ (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_removefilter.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.removeFromFilter_ baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_removefilter_baseline_test::cleanup
} -result 1

cleanupTests
