package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_scroll_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_scroll_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_scroll_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_scroll_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_scroll_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistFirst(.glistShell.glist) 5
    set ::glistVisibleLn(.glistShell.glist) 10
    set ::glistTotal(.glistShell.glist) 40

    glist.ybar_ .glistShell.glist scroll 1 units
    lappend lines [list ybar.unit.after [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list ybar.unit.first $::glistFirst(.glistShell.glist)]

    glist.ybar_ .glistShell.glist scroll -1 pages
    lappend lines [list ybar.page.after [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list ybar.page.first $::glistFirst(.glistShell.glist)]

    glist.ybar_ .glistShell.glist moveto 0.95
    lappend lines [list ybar.moveto.after [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list ybar.moveto.first $::glistFirst(.glistShell.glist)]

    glist.ybar_ .glistShell.glist -1
    lappend lines [list ybar.wheel.after [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list ybar.wheel.first $::glistFirst(.glistShell.glist)]

    set ::glistFirst(.glistShell.glist) 10
    set ::glistVisibleLn(.glistShell.glist) 4
    set ::glistLoaded(.glistShell.glist) 5
    set ::glistTotal(.glistShell.glist) 40
    glist.yscroll_ .glistShell.glist 0.2 0.6
    lappend lines [list yscroll.pin.yview [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist yview.calls]]

    set ::glistFirst(.glistShell.glist) 0
    set ::glistVisibleLn(.glistShell.glist) 4
    set ::glistLoaded(.glistShell.glist) 5
    set ::glistTotal(.glistShell.glist) 40
    glist.yscroll_ .glistShell.glist 0 1
    lappend lines [list yscroll.grow.after [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list yscroll.grow.visible $::glistVisibleLn(.glistShell.glist)]
    lappend lines [list yscroll.grow.scrollproxy [::scid_test::gui_fixtures::glist_widget::scrollProxyCalls]]

    set ::glistFirst(.glistShell.glist) 10
    set ::glistVisibleLn(.glistShell.glist) 4
    set ::glistLoaded(.glistShell.glist) 5
    set ::glistTotal(.glistShell.glist) 40
    glist.yscroll_ .glistShell.glist 0 0.5
    lappend lines [list yscroll.translate.scrollproxy [::scid_test::gui_fixtures::glist_widget::scrollProxyCalls]]
    lappend lines [list yscroll.translate.visible $::glistVisibleLn(.glistShell.glist)]

    return [join $lines "\n"]
}

test gui-glist-scroll-baseline-compare-1.0 {glist scroll helpers match the approved baseline} -setup {
    ::gui_glist_scroll_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_scroll_baseline_test::stubbedCommands 1 0 0
    ::gui_glist_scroll_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_scroll_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_scroll.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist scroll helpers (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_scroll.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist scroll baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_scroll_baseline_test::cleanup
} -result 1

cleanupTests
