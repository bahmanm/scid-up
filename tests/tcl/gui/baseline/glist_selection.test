package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_selection_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_selection_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_selection_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_selection_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_selection_baseline_test::formatSnapshot {} {
    set lines {}

    ::scid_test::gui_fixtures::glist_widget::setTreeviewRows .glistShell.glist {
        {10_0 {10 1-0 35 White Black} fsmall}
        {11_0 {11 0-1 40 Alpha Beta} fsmall}
        {12_0 {12 ½-½ 50 Current Opp} fsmall}
    }
    set ::glistFirst(.glistShell.glist) 10

    glist.select_ .glistShell.glist 13
    lappend lines [list select.absolute [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    glist.select_ .glistShell.glist end
    lappend lines [list select.end [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewSelection .glistShell.glist {}
    glist.movesel_ .glistShell.glist next +1 end
    lappend lines [list movesel.empty [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewSelection .glistShell.glist 10_0
    glist.movesel_ .glistShell.glist next +1 end
    lappend lines [list movesel.visible [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewBBox .glistShell.glist 12_0 ""
    glist.movesel_ .glistShell.glist next +1 end
    lappend lines [list movesel.hidden [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewSelection .glistShell.glist 10_0
    glist.movesel_ .glistShell.glist prev -1 0
    lappend lines [list ybar.calls [::scid_test::gui_fixtures::glist_widget::ybarCalls]]
    lappend lines [list after.calls [::scid_test::gui_fixtures::glist_widget::afterCalls]]
    lappend lines [list selection.final [::scid_test::gui_fixtures::glist_widget::treeviewState .glistShell.glist selection]]

    return [join $lines "\n"]
}

test gui-glist-selection-baseline-compare-1.0 {glist selection helpers match the approved baseline} -setup {
    ::gui_glist_selection_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_selection_baseline_test::stubbedCommands
    ::gui_glist_selection_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_selection_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_selection.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist selection helpers (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_selection.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist selection baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_selection_baseline_test::cleanup
} -result 1

cleanupTests
