package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_sortclick_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_sortclick_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_sortclick_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_sortclick_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_sortclick_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistBase(.glistShell.glist) 1
    ::scid_test::gui_fixtures::glist_widget::setBaseFilename 1 /tmp/base-1.si4

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 10 5 #2
    glist.sortClickEvent_ .glistShell.glist 10 5 0 TestLayout
    lappend lines [list first.sort $::glist_Sort(TestLayout)]
    lappend lines [list first.sortstr $::glistSortStr(.glistShell.glist)]
    lappend lines [list first.white.image [dict get [::scid_test::gui_fixtures::glist_widget::treeviewHeadingCalls .glistShell.glist] 3 -image]]
    lappend lines [list update.calls [::scid_test::gui_fixtures::glist_widget::updateDelegateCalls]]
    lappend lines [list busy.calls [::scid_test::gui_fixtures::glist_widget::busyCalls]]

    glist.sortClickEvent_ .glistShell.glist 10 5 0 TestLayout
    lappend lines [list second.sort $::glist_Sort(TestLayout)]
    lappend lines [list second.white.image [dict get [::scid_test::gui_fixtures::glist_widget::treeviewHeadingCalls .glistShell.glist] 3 -image]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 11 5 #3
    glist.sortClickEvent_ .glistShell.glist 11 5 4 TestLayout
    lappend lines [list third.sort $::glist_Sort(TestLayout)]
    lappend lines [list third.sortstr $::glistSortStr(.glistShell.glist)]
    lappend lines [list third.black.image [dict get [::scid_test::gui_fixtures::glist_widget::treeviewHeadingCalls .glistShell.glist] 4 -image]]

    ::scid_test::gui_fixtures::glist_widget::setTreeviewIdentifyColumn .glistShell.glist 12 5 #21
    glist.sortClickEvent_ .glistShell.glist 12 5 0 TestLayout
    lappend lines [list final.sort $::glist_Sort(TestLayout)]
    lappend lines [list recent.sort $::recentSort]

    return [join $lines "\n"]
}

test gui-glist-sortclick-baseline-compare-1.0 {glist.sortClickEvent_ matches the approved baseline} -setup {
    ::gui_glist_sortclick_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_sortclick_baseline_test::stubbedCommands 1 1 1 1 0 0
    ::gui_glist_sortclick_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_sortclick_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_sortclick.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.sortClickEvent_ (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_sortclick.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.sortClickEvent_ baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_sortclick_baseline_test::cleanup
} -result 1

cleanupTests
