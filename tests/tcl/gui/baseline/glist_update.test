package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures glist_widget.tcl]

namespace eval ::gui_glist_update_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_glist_update_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::setup stubbedCommands
}

proc ::gui_glist_update_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::glist_widget::cleanup stubbedCommands
}

proc ::gui_glist_update_baseline_test::seedHeaderTranslations {} {
    foreach col $::glist_Headers {
        set ::tr($col) $col
    }
}

proc ::gui_glist_update_baseline_test::formatSnapshot {} {
    set lines {}

    set ::glistFirst(.glistShell.glist) 7
    ::scid_test::gui_fixtures::glist_widget::setFilterSizes 1 dbfilter {5 10 20}
    glist.update .glistShell 1 dbfilter 1
    lappend lines [list partial.text [::scid_test::widgets::getState .glistShell.find.size -text]]
    lappend lines [list partial.reset.state [::scid_test::widgets::getState .glistShell.find.reset -state]]
    lappend lines [list partial.first $::glistFirst(.glistShell.glist)]

    set ::glistFirst(.glistShell.glist) 9
    ::scid_test::gui_fixtures::glist_widget::setFilterSizes 1 dbfilter {10 10 10}
    glist.update .glistShell 1 dbfilter 0
    lappend lines [list all.text [::scid_test::widgets::getState .glistShell.find.size -text]]
    lappend lines [list all.reset.state [::scid_test::widgets::getState .glistShell.find.reset -state]]
    lappend lines [list all.first $::glistFirst(.glistShell.glist)]

    lappend lines [list update.delegate.calls [::scid_test::gui_fixtures::glist_widget::updateDelegateCalls]]
    lappend lines [list glist.filter $::glistFilter(.glistShell.glist)]
    lappend lines [list glist.total $::glistTotal(.glistShell.glist)]

    return [join $lines "\n"]
}

test gui-glist-update-baseline-compare-1.0 {glist.update shell matches the approved baseline} -setup {
    ::gui_glist_update_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::glist_widget::installRuntimeStubs ::gui_glist_update_baseline_test::stubbedCommands 1 1
    ::gui_glist_update_baseline_test::seedHeaderTranslations

    glist.create .glistShell TestLayout
    set actual [::gui_glist_update_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] glist_update.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: glist.update shell (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/glist_update.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "glist.update baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_glist_update_baseline_test::cleanup
} -result 1

cleanupTests
