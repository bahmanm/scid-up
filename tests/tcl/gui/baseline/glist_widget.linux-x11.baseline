treeview .glistShell.glist -displaycolumns {7 3 4 5 6 1 2 23 8 10 9 16 17 22 21 18 11 12 13 14 15 0} -yscrollcommand {glist.yscroll_ .glistShell.glist}
ybar.command {glist.ybar_ .glistShell.glist}
sortInit.calls {{.glistShell.glist TestLayout}}
mouseWheel.bindings {{.glistShell.glist {glist.ybar_ .glistShell.glist}}}
treeview.tag.configure {{current -background steelBlue} {fsmall -font font_Small} {deleted -foreground #a5a2ac}}
widget .glistShell.find.advanced -image ::icon::filter_adv -command {apply {{w} { set w_top [regexp -inline {^\.[^.]+} $w] ::search::header $::gamelistBase($w_top) $::gamelistFilter($w_top) }} .glistShell} -style Toolbutton
widget .glistShell.find.reset -image ::icon::filter_reset -command {apply {{w} { $w.find.text delete 0 end $w.find.filter invoke }} .glistShell} -style Toolbutton
widget .glistShell.find.filter -image ::icon::filter_go -command {glist.findgame_ .glistShell awe} -style Toolbutton
widget .glistShell.find.b1_text -image ::icon::arrow_down16 -command {apply {{w} { after cancel [list glist.findgame_ $w 1] after idle [list glist.findgame_ $w 1] }} .glistShell} -style Toolbutton
widget .glistShell.find.b2_text -image ::icon::arrow_up16 -command {apply {{w} { after cancel [list glist.findgame_ $w 0] after idle [list glist.findgame_ $w 0] }} .glistShell} -style Toolbutton
widget .glistShell.find.scale -command {glist.ybar_ .glistShell.glist moveto}
bind .glistShell <<FindBarHide>> {glist.showfindbar_ .glistShell.glist TestLayout 0}
bind .glistShell <<FindBarShow>> {glist.showfindbar_ .glistShell.glist TestLayout 1}
bind .glistShell.find.text <Escape> {apply {{w layout} { glist.showfindbar_ ${w}.glist $layout 0 } ::} .glistShell TestLayout}
bind .glistShell.find.text <KeyPress-Down> {apply {{w} { ${w}.find.b1_text invoke return -code break } ::} .glistShell}
bind .glistShell.find.text <KeyPress-Up> {apply {{w} { ${w}.find.b2_text invoke return -code break } ::} .glistShell}
bind .glistShell.find.text <Return> {.glistShell.find.filter invoke}
bind .glistShell.glist <2> {glist.popupmenu_ %W %x %y %X %Y TestLayout}
bind .glistShell.glist <3> {glist.popupmenu_ %W %x %y %X %Y TestLayout}
bind .glistShell.glist <ButtonPress-1> {glist.press_ %W %x %y}
bind .glistShell.glist <ButtonRelease-1> {glist.release_ %W %x %y %s TestLayout}
bind .glistShell.glist <Command-f> {apply {{w} { event generate $w <<FindBarShow>> } ::} .glistShell}
bind .glistShell.glist <Control-Delete> {lassign [split [%W selection] "_"] idx ply if {$idx ne ""} { glist.movesel_ %W next +1 end; sc_filter remove $::glistBase(%W) $::glistFilter(%W) $idx ::notify::DatabaseModified $::glistBase(%W) } break}
bind .glistShell.glist <Control-End> {glist.ybar_ %W moveto 1; break}
bind .glistShell.glist <Control-Home> {glist.ybar_ %W moveto 0; break}
bind .glistShell.glist <Delete> {lassign [split [%W selection] "_"] idx ply if {$idx ne ""} { glist.delflag_ %W $idx glist.movesel_ %W next +1 end } break}
bind .glistShell.glist <Destroy> {glist.destroy_ %W}
bind .glistShell.glist <Double-ButtonRelease-1> {glist.doubleclick_ %W %x %y TestLayout}
bind .glistShell.glist <KeyPress-Down> {glist.movesel_ %W next +1 end; break}
bind .glistShell.glist <KeyPress-Left> continue
bind .glistShell.glist <KeyPress-Next> {glist.ybar_ %W scroll 1 pages; break}
bind .glistShell.glist <KeyPress-Prior> {glist.ybar_ %W scroll -1 pages; break}
bind .glistShell.glist <KeyPress-Return> {lassign [split [%W selection] "_"] idx ply if {$idx ne ""} { ::file::SwitchToBase $::glistBase(%W) 0 ::game::Load $idx $ply } break}
bind .glistShell.glist <KeyPress-Right> continue
bind .glistShell.glist <KeyPress-Up> {glist.movesel_ %W prev -1 0; break}
bind .glistShell.glist <Menu> {glist.popupmenu_ %W %x %y %X %Y TestLayout}
