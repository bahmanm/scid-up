package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_main_evalbar_menu_baseline_test {
    variable stubbedCommands {}
    variable enginesList {}
    variable engineNames {}
    variable tempRoot ""
}

proc ::gui_main_evalbar_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_main_evalbar_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_main_evalbar_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::macOS 0

    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        return
    }

    set ::gui_main_evalbar_menu_baseline_test::tempRoot [::scid_test::makeTempRoot [namespace current]]
    set _photosRoot $::gui_main_evalbar_menu_baseline_test::tempRoot
    foreach dirVar {::scidDataDir ::scidUserDir ::scidConfigDir ::scidShareDir} {
        set $dirVar $_photosRoot
    }
    file mkdir [file join $::scidShareDir photos]
    unset _photosRoot

    namespace eval ::board {}
    namespace eval ::board::mark {}
    namespace eval ::enginewin {}
    namespace eval ::enginecfg {}

    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    set ::gui_main_evalbar_menu_baseline_test::enginesList {}
    set ::gui_main_evalbar_menu_baseline_test::engineNames {}

    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands ::enginewin::listEngines {} {
        return $::gui_main_evalbar_menu_baseline_test::enginesList
    }
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_baseline_test::stubbedCommands ::enginecfg::names {} {
        return $::gui_main_evalbar_menu_baseline_test::engineNames
    }
}

proc ::gui_main_evalbar_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_main_evalbar_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::deleteTempRoot $::gui_main_evalbar_menu_baseline_test::tempRoot
    set ::gui_main_evalbar_menu_baseline_test::tempRoot ""

    unset -nocomplain ::mainEvalBarEngineID_
    unset -nocomplain ::mainEvalBarCheckbutton
    unset -nocomplain ::showMainEvalBarArrow
}

test gui-main-evalbar-menu-baseline-compare-1.0 {Main eval bar context menu matches the approved baseline structure} -setup {
    ::gui_main_evalbar_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    set ::gui_main_evalbar_menu_baseline_test::enginesList [list \
        [list 1 Stockfish 1] \
        [list 2 Leela 1] \
        [list 3 Ethereal 0] \
    ]
    set ::gui_main_evalbar_menu_baseline_test::engineNames {Stockfish Leela Komodo}

    set ::mainEvalBarEngineID_ 1
    set ::showMainEvalBarArrow 1

    ::createMainEvalBarMenu .main.board
    set snapshot [::scid_test::menu_structure::snapshot .main.board.evalbar_menu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] main_evalbar_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: main eval bar context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/main_evalbar_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Main eval bar menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_main_evalbar_menu_baseline_test::cleanup
} -result 1

cleanupTests
