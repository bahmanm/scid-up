package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_pgn_context_menu_baseline_test {
    variable stubbedCommands {}
    variable scVarLevel 1
}

proc ::gui_pgn_context_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_pgn_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_pgn_context_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::pgn {}
    namespace eval ::board {}
    namespace eval ::htext {}

    set ::gui_pgn_context_menu_baseline_test::scVarLevel 1

    ::scid_test::mocks::stubCommand ::gui_pgn_context_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_context_menu_baseline_test::stubbedCommands sc_var {subcmd args} {
        if {$subcmd ne "level"} {
            error "sc_var $subcmd not stubbed in tests"
        }
        return $::gui_pgn_context_menu_baseline_test::scVarLevel
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_context_menu_baseline_test::stubbedCommands tk_popup {menu x y} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_context_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_context_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }
}

proc ::gui_pgn_context_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_pgn_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
}

test gui-pgn-context-menu-baseline-compare-1.0 {PGN text context menu matches the approved baseline structure} -setup {
    ::gui_pgn_context_menu_baseline_test::setup
} -body {
    # Arrange/Act: build the context menu under the harness.
    source [file join [::scid_test::tclDir] windows pgn.tcl]

    set win .pgnWin.text
    ::pgn::contextMenu $win 10 20

    set snapshot [::scid_test::menu_structure::snapshot ${win}.ctxtMenu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] pgn_context_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: PGN text context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/pgn_context_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "PGN context menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_pgn_context_menu_baseline_test::cleanup
} -result 1

cleanupTests

