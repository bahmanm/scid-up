# ScidUp UI baseline: PGN window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/pgn_window.test

text .pgnWin.text -wrap word -tabs {1c right 2c 4c}
menu.format {menu .pgnWin.menu dynamic 0 entries {
  {type cascade label PgnFile acc {} state normal underline 0 submenu {
    menu .pgnWin.menu.file dynamic 0 entries {
      {type command label PgnFileCopy acc {} state normal underline 0 submenu {}}
      {type command label PgnFilePrint acc {} state normal underline 0 submenu {}}
      {type separator label {} acc {} state normal underline 0 submenu {}}
      {type command label PgnFileClose acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label PgnOpt acc {} state normal underline 0 submenu {
    menu .pgnWin.menu.opt dynamic 0 entries {
      {type checkbutton label PgnOptColor acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptShort acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptSymbols acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptIndentC acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptIndentV acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptSpace acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptColumn acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptStripMarks acc {} state normal underline 0 submenu {}}
      {type checkbutton label PgnOptBoldMainLine acc {} state normal underline 0 submenu {}}
      {type checkbutton label GInfoPhotos acc {} state normal underline 0 submenu {}}
      {type checkbutton label {Notation Figurine} acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label PgnColor acc {} state normal underline 0 submenu {
    menu .pgnWin.menu.color dynamic 0 entries {
      {type command label PgnColorAnno acc {} state normal underline 0 submenu {}}
      {type command label PgnColorComments acc {} state normal underline 0 submenu {}}
      {type command label PgnColorVars acc {} state normal underline 0 submenu {}}
      {type command label PgnColorCurrent acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label PgnHelp acc {} state normal underline 0 submenu {
    menu .pgnWin.menu.helpmenu dynamic 0 entries {
      {type command label PgnHelpPgn acc {} state normal underline 0 submenu {}}
      {type command label PgnHelpIndex acc {} state normal underline 0 submenu {}}
    }
  }}
}}
binds .pgnWin <Destroy>
binds .pgnWin.text {<ButtonPress-1> <ButtonPress-3>}
