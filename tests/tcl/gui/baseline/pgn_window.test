package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_pgn_window_baseline_test {
    variable stubbedCommands {}
    variable bindCalls {}
}

proc ::gui_pgn_window_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_pgn_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_pgn_window_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 0

    set ::gui_pgn_window_baseline_test::bindCalls {}

    set ::language E
    set ::MB3 3

    array set ::tr {
        PgnWindowTitle PgnWindowTitle
    }

    namespace eval ::win {}
    namespace eval ::pgn {}

    set ::pgn::boldMainLine 0

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands tr {tag {lang ""}} {
        if {[info exists ::tr($tag)]} { return $::tr($tag) }
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ::win::createWindow {w title args} {
        if {[llength [info commands $w]]} { return 0 }
        ::scid_test::widgets::defineWidget $w
        return 1
    }
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ::win::closeWindow {w} { return }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ::setMenu {w menuPath} { return }
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands translateMenuLabels {menuPath} { return }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ttk_text {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineTextWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ::ttk::frame {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands autoscrollBars {args} { return }
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands grid {args} { return }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands bind {w seq script} {
        lappend ::gui_pgn_window_baseline_test::bindCalls [list $w $seq $script]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands focus {w} { return }

    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }
}

proc ::gui_pgn_window_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_pgn_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
    unset -nocomplain ::language
    unset -nocomplain ::MB3
    unset -nocomplain ::pgnWin
}

proc ::gui_pgn_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list text .pgnWin.text \
        -wrap [::scid_test::widgets::getState .pgnWin.text -wrap] \
        -tabs [::scid_test::widgets::getState .pgnWin.text -tabs] \
    ]

    lappend lines [list menu.format [::scid_test::menu_structure::format [::scid_test::menu_structure::snapshot .pgnWin.menu]]]

    set sequencesByWidget {}
    foreach call $::gui_pgn_window_baseline_test::bindCalls {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    return [join $lines "\n"]
}

test gui-pgn-window-baseline-compare-1.0 {PGN window skeleton matches the approved baseline structure} -setup {
    ::gui_pgn_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows pgn.tcl]
    ::scid_test::mocks::stubCommand ::gui_pgn_window_baseline_test::stubbedCommands ::pgn::ResetColors {} { return }

    ::pgn::OpenClose
    set actual [::gui_pgn_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] pgn_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: PGN window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/pgn_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "PGN window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_pgn_window_baseline_test::cleanup
} -result 1

cleanupTests
