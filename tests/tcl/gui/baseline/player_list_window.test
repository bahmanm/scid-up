package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures player_list_window.tcl]

namespace eval ::gui_player_list_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_player_list_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::player_list_window::setup stubbedCommands
}

proc ::gui_player_list_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::player_list_window::cleanup stubbedCommands

    unset -nocomplain ::plistWin
    catch {namespace delete ::plist}
}

proc ::gui_player_list_window_baseline_test::formatSnapshot {} {
    set lines {}

    set t .plist.t.text
    lappend lines [list text $t \
        -width [::scid_test::widgets::getState $t -width] \
        -height [::scid_test::widgets::getState $t -height] \
        -wrap [::scid_test::widgets::getState $t -wrap] \
        -font [::scid_test::widgets::getState $t -font] \
        -state [::scid_test::widgets::getState $t -state] \
        -tabs [::scid_test::widgets::getState $t -tabs] \
    ]

    set tagCfg [::scid_test::widgets::getTagConfigureCalls $t]
    foreach tag {ng date elo title} {
        set found 0
        foreach call $tagCfg {
            if {[lindex $call 0] eq $tag} {
                set found 1
                break
            }
        }
        lappend lines [list tag $tag configured $found]
    }

    set sequences {}
    foreach call [::scid_test::gui_fixtures::player_list_window::bindCalls] {
        lappend sequences [lindex $call 1]
    }
    lappend lines [list binds [lsort -unique $sequences]]

    set focusLast ""
    set focusCalls [::scid_test::gui_fixtures::player_list_window::focusCalls]
    if {[llength $focusCalls] > 0} {
        set focusLast [lindex $focusCalls end]
    }
    lappend lines [list focus.last $focusLast]

    return [join $lines "\n"]
}

test gui-player-list-window-baseline-compare-1.0 {Player list window skeleton matches the approved baseline structure} -setup {
    ::gui_player_list_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows pfinder.tcl]
    ::scid_test::mocks::stubCommand ::gui_player_list_window_baseline_test::stubbedCommands ::plist::refresh {args} {
        return
    }

    ::plist::Open
    set actual [::gui_player_list_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] player_list_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Player list window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/player_list_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Player list window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_player_list_window_baseline_test::cleanup
} -result 1

cleanupTests
