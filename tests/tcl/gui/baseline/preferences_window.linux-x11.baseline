# ScidUp UI baseline: Preferences window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/preferences_window.test

win::createWindow .preferences ConfigureScid
widget .preferences.c -highlightthickness 0
canvas .preferences.c create window 0 0 -window .preferences.c.f -anchor nw
treeview .preferences.options.list -height 8 column0.width 228 selection 0
treeview.item 0 values OptionsBoard
treeview.item 1 values OptionsFonts
treeview.item 2 values OptionsToolbar
treeview.item 3 values OptionsInternationalization
treeview.item 4 values OptionsRecent
treeview.item 5 values OptionsSounds
treeview.item 6 values OptionsMoves
treeview.item 7 values ConfigureInformant
bind .preferences.options.list <<TreeviewSelect>> {apply {{w} {
    ::preferences::replaceConfig [%W selection] ${w}.c
  } ::} .preferences}
bind .preferences.c.f <Configure> {::preferences::updateScrollBar .preferences.c}
initCalls {{chooseBoardColors .preferences.c.f.0} {::preferences::fonts .preferences.c.f.1} {ConfigToolbar .preferences.c.f.2} {::preferences::internationalization .preferences.c.f.3} {::recentFiles::configure .preferences.c.f.4} {::utils::sound::OptionsDialog .preferences.c.f.5} {::preferences::moves .preferences.c.f.6} {configInformant .preferences.c.f.7}}
focusCalls .preferences.options
