package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures preferences_window.tcl]

namespace eval ::gui_preferences_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_preferences_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::preferences_window::setup stubbedCommands
}

proc ::gui_preferences_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::preferences_window::cleanup stubbedCommands
}

proc ::gui_preferences_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list win::createWindow {*}[lindex [::scid_test::gui_fixtures::preferences_window::winCreateCalls] 0]]

    lappend lines [list widget .preferences.c -highlightthickness [::scid_test::gui_fixtures::preferences_window::canvasState .preferences.c -highlightthickness]]

    set createCall [lindex [::scid_test::gui_fixtures::preferences_window::canvasCreateCalls .preferences.c] 0]
    lappend lines [list canvas .preferences.c create {*}$createCall]

    lappend lines [list treeview .preferences.options.list \
        -height [::scid_test::gui_fixtures::preferences_window::treeviewState .preferences.options.list -height] \
        column0.width [::scid_test::gui_fixtures::preferences_window::treeviewColumnState .preferences.options.list 0 -width] \
        selection [::scid_test::gui_fixtures::preferences_window::treeviewSelection .preferences.options.list] \
    ]

    foreach item [::scid_test::gui_fixtures::preferences_window::treeviewInserted .preferences.options.list] {
        set id [lindex $item [expr {[lsearch -exact $item -id] + 1}]]
        set values [lindex $item [expr {[lsearch -exact $item -values] + 1}]]
        lappend lines [list treeview.item $id values $values]
    }

    foreach call [::scid_test::gui_fixtures::preferences_window::bindCalls] {
        lassign $call w seq script
        lappend lines [list bind $w $seq $script]
    }

    lappend lines [list initCalls [::scid_test::gui_fixtures::preferences_window::initCalls]]
    lappend lines [list focusCalls [::scid_test::gui_fixtures::preferences_window::focusCalls]]

    return [join $lines "\n"]
}

test gui-preferences-window-baseline-compare-1.0 {Preferences window skeleton matches the approved baseline structure} -setup {
    ::gui_preferences_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows preferences.tcl]

    ::scid_test::gui_fixtures::preferences_window::stubPaneInitialisers stubbedCommands

    ::preferences::Open
    set actual [::gui_preferences_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] preferences_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Preferences window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/preferences_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Preferences window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_preferences_window_baseline_test::cleanup
} -result 1

cleanupTests
