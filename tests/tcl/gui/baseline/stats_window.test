package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures stats_window.tcl]

namespace eval ::gui_stats_window_baseline_test {
    variable stubbedCommands {}
}

proc ::gui_stats_window_baseline_test::setup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::stats_window::setup stubbedCommands
}

proc ::gui_stats_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::stats_window::cleanup stubbedCommands
}

proc ::gui_stats_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list text .statsWin.stats \
        -width [::scid_test::widgets::getState .statsWin.stats -width] \
        -height [::scid_test::widgets::getState .statsWin.stats -height] \
        -wrap [::scid_test::widgets::getState .statsWin.stats -wrap] \
        -font [::scid_test::widgets::getState .statsWin.stats -font] \
        -state [::scid_test::widgets::getState .statsWin.stats -state] \
    ]

    set sequences {}
    foreach call [::scid_test::gui_fixtures::stats_window::bindCalls] {
        lappend sequences [lindex $call 1]
    }
    set sequences [lsort -unique $sequences]
    lappend lines [list binds $sequences]

    return [join $lines "\n"]
}

test gui-stats-window-baseline-compare-1.0 {Filter Statistics window skeleton matches the approved baseline structure} -setup {
    ::gui_stats_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows stats.tcl]

    ::scid_test::mocks::stubCommand ::gui_stats_window_baseline_test::stubbedCommands ::windows::stats::refresh_wnd {} { return }

    ::windows::stats::Open
    set actual [::gui_stats_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] stats_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Filter Statistics window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/stats_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Stats window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_stats_window_baseline_test::cleanup
} -result 1

cleanupTests
