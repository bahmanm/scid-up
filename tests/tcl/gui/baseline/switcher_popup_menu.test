package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_switcher_popup_menu_baseline_test {
    variable stubbedCommands {}
    variable baseReadonly 0
    variable autoLoadPresent 0
}

proc ::gui_switcher_popup_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_popup_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_switcher_popup_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::windows {}
    namespace eval ::windows::switcher {}
    namespace eval ::file {}
    namespace eval ::file::autoLoadBases {}

    set ::gui_switcher_popup_menu_baseline_test::baseReadonly 0
    set ::gui_switcher_popup_menu_baseline_test::autoLoadPresent 0

    array set ::tr {CompactDatabase CompactDatabase}

    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands tk_popup {menu x y} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands sc_base {subcmd args} {
        if {$subcmd ne "isReadOnly"} {
            error "sc_base $subcmd not stubbed in tests"
        }
        return $::gui_switcher_popup_menu_baseline_test::baseReadonly
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands ::file::autoLoadBases.find {baseIdx} {
        if {$::gui_switcher_popup_menu_baseline_test::autoLoadPresent} {
            return 0
        }
        return -1
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands ::file::autoLoadBases.add {baseIdx} {
        return
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_popup_menu_baseline_test::stubbedCommands ::file::autoLoadBases.remove {baseIdx} {
        return
    }
}

proc ::gui_switcher_popup_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_popup_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
    unset -nocomplain ::sw_DummyCheckbutton
}

test gui-switcher-popup-menu-baseline-compare-1.0 {Switcher tile popup menu matches the approved baseline structure} -setup {
    ::gui_switcher_popup_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows switcher.tcl]

    set ::clipbase_db 0

    set w .sw.c.f1
    menu ${w}.menu

    set ::gui_switcher_popup_menu_baseline_test::baseReadonly 0
    set ::gui_switcher_popup_menu_baseline_test::autoLoadPresent 0

    ::windows::switcher::popupmenu "" $w 10 20 1

    set snapshot [::scid_test::menu_structure::snapshot ${w}.menu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] switcher_popup_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: switcher tile popup menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/switcher_popup_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Switcher popup menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_switcher_popup_menu_baseline_test::cleanup
} -result 1

cleanupTests
