package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_switcher_window_baseline_test {
    variable stubbedCommands {}
    variable afterCalls {}
    variable canvasCounter 0

    variable canvasWindowByTag
    array set canvasWindowByTag {}

    variable canvasState
    array set canvasState {}
}

proc ::gui_switcher_window_baseline_test::defineCanvas {path} {
    catch {rename $path ""}
    interp alias {} $path {} ::gui_switcher_window_baseline_test::dispatchCanvas $path
    return $path
}

proc ::gui_switcher_window_baseline_test::dispatchCanvas {path subcmd args} {
    switch -- $subcmd {
        configure {
            if {[llength $args] % 2 != 0} {
                error "canvas $path configure expects option/value pairs, got: $args"
            }
            foreach {opt val} $args {
                set ::gui_switcher_window_baseline_test::canvasState($path,$opt) $val
            }
            return
        }
        create {
            set type [lindex $args 0]
            if {$type ne "window"} {
                return 0
            }
            set opts [lrange $args 3 end]
            set win ""
            set tag ""
            for {set i 0} {$i < [llength $opts]} {incr i 2} {
                set opt [lindex $opts $i]
                set val [lindex $opts [expr {$i + 1}]]
                if {$opt eq "-window"} { set win $val }
                if {$opt eq "-tag"} { set tag $val }
            }
            if {$tag ne "" && $win ne ""} {
                set ::gui_switcher_window_baseline_test::canvasWindowByTag($path,$tag) $win
            }
            incr ::gui_switcher_window_baseline_test::canvasCounter
            return $::gui_switcher_window_baseline_test::canvasCounter
        }
        itemconfigure -
        coords -
        yview -
        xview {
            return
        }
        default {
            return
        }
    }
}

proc ::gui_switcher_window_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_switcher_window_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 0

    namespace eval ::windows {}
    namespace eval ::windows::switcher {}

    set ::MB3 3

    set ::gui_switcher_window_baseline_test::afterCalls {}
    set ::gui_switcher_window_baseline_test::canvasCounter 0
    array unset ::gui_switcher_window_baseline_test::canvasWindowByTag
    array set ::gui_switcher_window_baseline_test::canvasWindowByTag {}
    array unset ::gui_switcher_window_baseline_test::canvasState
    array set ::gui_switcher_window_baseline_test::canvasState {}

    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands sc_info {subcmd args} {
        switch -- $subcmd {
            limit {
                if {[llength $args] >= 1 && [lindex $args 0] eq "bases"} {
                    return 3
                }
                return 0
            }
            default { return "" }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands canvas {path args} {
        ::gui_switcher_window_baseline_test::defineCanvas $path
        if {[llength $args]} {
            $path configure {*}$args
        }
        return $path
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands ::ttk::frame {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands ::ttk::label {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands grid {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands bind {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands autoscrollBars {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands applyThemeStyle {args} { return }

    ::scid_test::mocks::stubCommand ::gui_switcher_window_baseline_test::stubbedCommands after {args} {
        lappend ::gui_switcher_window_baseline_test::afterCalls $args
        return "after#scid_test"
    }
}

proc ::gui_switcher_window_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_window_baseline_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::MB3
}

proc ::gui_switcher_window_baseline_test::formatSnapshot {w} {
    set lines {}

    lappend lines "AFTER"
    lappend lines [join $::gui_switcher_window_baseline_test::afterCalls "\n"]

    lappend lines "TILES"
    foreach i {1 2 3} {
        set f $w.c.f$i
        lappend lines "tile $i"
        lappend lines [list canvasTag tag$i window $::gui_switcher_window_baseline_test::canvasWindowByTag($w.c,tag$i)]
        lappend lines [list label $f.img -image [::scid_test::widgets::getState $f.img -image] -style [::scid_test::widgets::getState $f.img -style]]
        lappend lines [list label $f.name -width [::scid_test::widgets::getState $f.name -width] -anchor [::scid_test::widgets::getState $f.name -anchor] -font [::scid_test::widgets::getState $f.name -font]]
        lappend lines [list label $f.ngames -text [::scid_test::widgets::getState $f.ngames -text] -width [::scid_test::widgets::getState $f.ngames -width] -anchor [::scid_test::widgets::getState $f.ngames -anchor] -font [::scid_test::widgets::getState $f.ngames -font]]
        lappend lines [list menu $f.menu -tearoff [$f.menu cget -tearoff]]
    }

    return [join $lines "\n"]
}

test gui-switcher-window-baseline-compare-1.0 {Switcher window skeleton matches the approved baseline structure} -setup {
    ::gui_switcher_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows switcher.tcl]

    set w .baseWin
    if {![llength [info commands $w]]} { ::scid_test::widgets::defineWidget $w }

    ::windows::switcher::Create $w
    set actual [::gui_switcher_window_baseline_test::formatSnapshot $w]

    set baselineFile [file join [file dirname [info script]] switcher_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: switcher window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/switcher_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Switcher window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_switcher_window_baseline_test::cleanup
} -result 1

cleanupTests

