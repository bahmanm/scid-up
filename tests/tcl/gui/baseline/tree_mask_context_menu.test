package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_tree_mask_context_menu_baseline_test {
    variable stubbedCommands {}
    variable posMoves {}
}

proc ::gui_tree_mask_context_menu_baseline_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_tree_mask_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_tree_mask_context_menu_baseline_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::tree {}
    namespace eval ::tree::mask {}

    set ::gui_tree_mask_context_menu_baseline_test::posMoves {}

    ::scid_test::mocks::stubCommand ::gui_tree_mask_context_menu_baseline_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_tree_mask_context_menu_baseline_test::stubbedCommands ::trans {text} {
        return $text
    }

    ::scid_test::mocks::stubCommand ::gui_tree_mask_context_menu_baseline_test::stubbedCommands sc_pos {subcmd args} {
        if {$subcmd ne "moves"} {
            error "sc_pos $subcmd not stubbed in tests"
        }
        return $::gui_tree_mask_context_menu_baseline_test::posMoves
    }

    ::scid_test::mocks::stubCommand ::gui_tree_mask_context_menu_baseline_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            pointerx { return 100 }
            pointery { return 200 }
            default {
                error "winfo $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_tree_mask_context_menu_baseline_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }
}

proc ::gui_tree_mask_context_menu_baseline_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_tree_mask_context_menu_baseline_test::stubbedCommands
    ::scid_test::menu_capture::reset
}

test gui-tree-mask-context-menu-baseline-compare-1.0 {Tree mask context menu matches the approved baseline structure} -setup {
    ::gui_tree_mask_context_menu_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows tree.tcl]

    set ::gui_tree_mask_context_menu_baseline_test::posMoves {e4 OK OQ}

    set win .treeWin1.f.tl
    ::tree::mask::contextMenu $win e4 0 0 0 0

    set snapshot [::scid_test::menu_structure::snapshot ${win}.ctxtMenu]
    set actual [::scid_test::menu_structure::format $snapshot]

    set baselineFile [file join [file dirname [info script]] tree_mask_context_menu.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Tree mask context menu (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/tree_mask_context_menu.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]

    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Tree mask context menu baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_tree_mask_context_menu_baseline_test::cleanup
} -result 1

cleanupTests

