# ScidUp UI baseline: Tree window skeleton (Linux/X11)
# Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/tree_window.test

text .treeWin1.f.tl -wrap none -exportselection 1 -font font_Fixed
menu.format {menu .treeWin1.menu dynamic 0 entries {
  {type cascade label TreeFile acc {} state normal underline 0 submenu {
    menu .treeWin1.menu.file dynamic 0 entries {
      {type cascade label TreeFileSetCacheSize acc {} state normal underline 0 submenu {
        menu .treeWin1.menu.file.size dynamic 0 entries {
          {type radiobutton label 250 acc {} state normal underline 0 submenu {}}
          {type radiobutton label 500 acc {} state normal underline 0 submenu {}}
          {type radiobutton label 1000 acc {} state normal underline 0 submenu {}}
          {type radiobutton label 2000 acc {} state normal underline 0 submenu {}}
          {type radiobutton label 5000 acc {} state normal underline 0 submenu {}}
          {type radiobutton label 10000 acc {} state normal underline 0 submenu {}}
        }
      }}
      {type command label TreeFileGraph acc {} state normal underline 0 submenu {}}
      {type command label TreeFileCopy acc {} state normal underline 0 submenu {}}
      {type command label TreeFileClose acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label TreeMask acc {} state normal underline 0 submenu {
    menu .treeWin1.menu.mask dynamic 0 entries {
      {type command label TreeMaskNew acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskOpen acc {} state normal underline 0 submenu {}}
      {type cascade label TreeMaskOpenRecent acc {} state normal underline 0 submenu {
        menu .treeWin1.menu.mask.recent dynamic 0 entries {
          {type command label mask-one acc {} state normal underline 0 submenu {}}
          {type command label mask-two acc {} state normal underline 0 submenu {}}
        }
      }}
      {type command label TreeMaskSave acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskClose acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskFillWithGame acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskFillWithBase acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskSearch acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskInfo acc {} state normal underline 0 submenu {}}
      {type command label TreeMaskDisplay acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label TreeSort acc {} state normal underline 0 submenu {
    menu .treeWin1.menu.sort dynamic 0 entries {
      {type radiobutton label TreeSortAlpha acc {} state normal underline 0 submenu {}}
      {type radiobutton label TreeSortECO acc {} state normal underline 0 submenu {}}
      {type radiobutton label TreeSortFreq acc {} state normal underline 0 submenu {}}
      {type radiobutton label TreeSortScore acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label TreeOpt acc {} state normal underline 0 submenu {
    menu .treeWin1.menu.opt dynamic 0 entries {
      {type checkbutton label TreeOptLock acc {} state normal underline 0 submenu {}}
      {type checkbutton label TreeOptTraining acc {} state normal underline 0 submenu {}}
    }
  }}
  {type cascade label TreeHelp acc {} state normal underline 0 submenu {
    menu .treeWin1.menu.helpmenu dynamic 0 entries {
      {type command label TreeHelpTree acc F1 state normal underline 0 submenu {}}
      {type command label TreeHelpIndex acc {} state normal underline 0 submenu {}}
    }
  }}
}}
tag bluefg configured 1
tag greenfg configured 1
tag redfg configured 1
binds .treeWin1 {<ButtonPress-1> <Destroy>}
refresh.calls 1
cachesize 1000
