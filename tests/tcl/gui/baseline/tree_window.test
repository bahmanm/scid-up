package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]
source [file join $tclTestsDir gui fixtures tree_window.tcl]

namespace eval ::gui_tree_window_baseline_test {
    variable stubbedCommands {}
    variable refreshCalls 0
}

proc ::gui_tree_window_baseline_test::setup {} {
    variable stubbedCommands
    set ::gui_tree_window_baseline_test::refreshCalls 0
    ::scid_test::gui_fixtures::tree_window::setup stubbedCommands
}

proc ::gui_tree_window_baseline_test::cleanup {} {
    variable stubbedCommands
    ::scid_test::gui_fixtures::tree_window::cleanup stubbedCommands
    catch {unset ::treeWin}
    catch {unset ::treeWin1}
    catch {namespace delete ::tree}
}

proc ::gui_tree_window_baseline_test::formatSnapshot {} {
    set lines {}

    lappend lines [list text .treeWin1.f.tl \
        -wrap [::scid_test::widgets::getState .treeWin1.f.tl -wrap] \
        -exportselection [::scid_test::widgets::getState .treeWin1.f.tl -exportselection] \
        -font [::scid_test::widgets::getState .treeWin1.f.tl -font] \
    ]

    lappend lines [list menu.format [::scid_test::menu_structure::format [::scid_test::menu_structure::snapshot .treeWin1.menu]]]

    set tagCfg [::scid_test::widgets::getTagConfigureCalls .treeWin1.f.tl]
    foreach tag {bluefg greenfg redfg} {
        set found 0
        foreach call $tagCfg {
            if {[lindex $call 0] eq $tag} {
                set found 1
                break
            }
        }
        lappend lines [list tag $tag configured $found]
    }

    set sequencesByWidget {}
    foreach call [::scid_test::gui_fixtures::tree_window::bindCalls] {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }
    foreach w [lsort [dict keys $sequencesByWidget]] {
        lappend lines [list binds $w [lsort -unique [dict get $sequencesByWidget $w]]]
    }

    lappend lines [list refresh.calls $::gui_tree_window_baseline_test::refreshCalls]
    lappend lines [list cachesize $::tree::cachesize(1)]

    return [join $lines "\n"]
}

test gui-tree-window-baseline-compare-1.0 {Tree window skeleton matches the approved baseline structure} -setup {
    ::gui_tree_window_baseline_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows tree.tcl]

    ::scid_test::mocks::stubCommand ::gui_tree_window_baseline_test::stubbedCommands ::tree::refresh {baseNumber} {
        incr ::gui_tree_window_baseline_test::refreshCalls
        return
    }

    ::tree::make
    set actual [::gui_tree_window_baseline_test::formatSnapshot]

    set baselineFile [file join [file dirname [info script]] tree_window.linux-x11.baseline]

    if {[info exists ::env(SCIDUP_UPDATE_UI_BASELINES)] && $::env(SCIDUP_UPDATE_UI_BASELINES) ne ""} {
        ::scid_test::baseline_io::writeListFile $baselineFile $actual [list \
            "ScidUp UI baseline: Tree window skeleton (Linux/X11)" \
            "Generated by: SCIDUP_UPDATE_UI_BASELINES=1 tclsh tests/tcl/run_one_test.tcl gui/baseline/tree_window.test" \
        ]
        return 1
    }

    set expected [::scid_test::baseline_io::readListFile $baselineFile]
    if {$expected ne $actual} {
        set diff [::scid_test::baseline_io::unifiedDiff $expected $actual]
        error "Tree window baseline mismatch: $baselineFile\n\n$diff"
    }

    return 1
} -cleanup {
    ::gui_tree_window_baseline_test::cleanup
} -result 1

cleanupTests
