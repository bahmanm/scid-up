package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_crosstab_window_spec_test {
    variable stubbedCommands {}
    variable bindCalls {}
}

proc ::gui_crosstab_window_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_crosstab_window_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_crosstab_window_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 0

    set ::gui_crosstab_window_spec_test::bindCalls {}

    set ::language E

    array set ::tr {
        ToolsCross ToolsCross
        Stop Stop
        Update Update
        Close Close
        SetFilter SetFilter
        AddToFilter AddToFilter
        CrosstabOptAll CrosstabOptAll
        CrosstabOptSwiss CrosstabOptSwiss
        CrosstabOptKnockout CrosstabOptKnockout
        CrosstabOptAuto CrosstabOptAuto
        CrosstabFile CrosstabFile
        CrosstabEdit CrosstabEdit
        CrosstabOpt CrosstabOpt
        CrosstabSort CrosstabSort
        CrosstabText CrosstabText
        CrosstabHelp CrosstabHelp
        CrosstabHelpCross CrosstabHelpCross
        CrosstabHelpIndex CrosstabHelpIndex
        CrosstabFileText CrosstabFileText
        CrosstabFileHtml CrosstabFileHtml
        CrosstabFileLaTeX CrosstabFileLaTeX
        CrosstabFileClose CrosstabFileClose
        CrosstabEditEvent CrosstabEditEvent
        CrosstabEditSite CrosstabEditSite
        CrosstabEditDate CrosstabEditDate
        CrosstabOptAll CrosstabOptAll
        CrosstabOptSwiss CrosstabOptSwiss
        CrosstabOptKnockout CrosstabOptKnockout
        CrosstabOptAuto CrosstabOptAuto
        CrosstabOptAges CrosstabOptAges
        CrosstabOptNats CrosstabOptNats
        CrosstabOptRatings CrosstabOptRatings
        CrosstabOptTitles CrosstabOptTitles
        CrosstabOptBreaks CrosstabOptBreaks
        CrosstabOptDeleted CrosstabOptDeleted
        CrosstabOptColors CrosstabOptColors
        CrosstabOptColumnNumbers CrosstabOptColumnNumbers
        CrosstabOptGroup CrosstabOptGroup
        CrosstabSortName CrosstabSortName
        CrosstabSortRating CrosstabSortRating
        CrosstabSortScore CrosstabSortScore
        CrosstabColorPlain CrosstabColorPlain
        CrosstabColorHyper CrosstabColorHyper
    }

    namespace eval ::win {}
    namespace eval ::htext {}
    namespace eval ::crosstab {}

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands tr {tag {lang ""}} {
        if {[info exists ::tr($tag)]} { return $::tr($tag) }
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::win::createWindow {w title args} {
        if {[llength [info commands $w]]} {
            return 0
        }
        ::scid_test::widgets::defineWidget $w
        return 1
    }
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::win::makeVisible {w} { return }
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::win::closeWindow {w} { return }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::setMenu {w menuPath} { return }
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands translateMenuLabels {menuPath} { return }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::htext::init {w} { return }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands autoscrollText {bars frame widget style} {
        if {![llength [info commands $frame]]} { ::scid_test::widgets::defineWidget $frame }
        if {![llength [info commands $widget]]} { ::scid_test::widgets::defineTextWidget $widget }
        return
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    foreach cmd {frame button menubutton} {
        ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::ttk::$cmd {path args} {
            if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
            if {[llength $args]} { $path configure {*}$args }
            return $path
        }
    }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands pack {args} { return }
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands bind {w seq script} {
        lappend ::gui_crosstab_window_spec_test::bindCalls [list $w $seq $script]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands focus {w} { return }

    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }
}

proc ::gui_crosstab_window_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_crosstab_window_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
    unset -nocomplain ::language
}

test gui-crosstab-window-spec-skeleton-1.0 {Crosstable window creates stable menus, main text widget, and binds focus on click} -setup {
    ::gui_crosstab_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows crosstab.tcl]

    # Avoid refresh dependencies (sc_game/sc_base/etc.) while asserting structure.
    ::scid_test::mocks::stubCommand ::gui_crosstab_window_spec_test::stubbedCommands ::crosstab::Refresh {} { return }

    ::crosstab::Open

    foreach p {.crosstableWin .crosstableWin.menu .crosstableWin.menu.file .crosstableWin.menu.edit .crosstableWin.menu.opt .crosstableWin.menu.sort .crosstableWin.menu.color .crosstableWin.menu.helpmenu .crosstableWin.f .crosstableWin.f.text .crosstableWin.b .crosstableWin.b.stop .crosstableWin.b.type .crosstableWin.b.type.menu} {
        if {![llength [info commands $p]]} {
            error "Expected widget command to exist: $p"
        }
    }

    if {[.crosstableWin.menu.file cget -tearoff] ne "0"} {
        error "Expected .crosstableWin.menu.file -tearoff 0"
    }

    set menuSnapshot [::scid_test::menu_structure::format [::scid_test::menu_structure::snapshot .crosstableWin.menu]]
    set sequencesByWidget {}
    foreach call $::gui_crosstab_window_spec_test::bindCalls {
        lassign $call w seq script
        dict lappend sequencesByWidget $w $seq
    }

    list \
        [::scid_test::widgets::getState .crosstableWin.f.text -wrap] \
        [::scid_test::widgets::getState .crosstableWin.f.text -font] \
        [::scid_test::widgets::getState .crosstableWin.f.text -state] \
        [string match "*type cascade label CrosstabFile*" $menuSnapshot] \
        [lsort -unique [dict get $sequencesByWidget .crosstableWin.f.text]]
} -cleanup {
    ::gui_crosstab_window_spec_test::cleanup
} -result {none font_Fixed normal 1 <ButtonPress-1>}

cleanupTests

