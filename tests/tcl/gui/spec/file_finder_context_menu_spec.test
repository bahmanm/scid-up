package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_file_finder_context_menu_spec_test {
    variable stubbedCommands {}
}

proc ::gui_file_finder_context_menu_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_context_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_file_finder_context_menu_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::file {}
    namespace eval ::file::finder {}

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_spec_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_spec_test::stubbedCommands update {args} {
        return
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_spec_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            pointerx { return 100 }
            pointery { return 200 }
            default {
                error "winfo $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_file_finder_context_menu_spec_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }
}

proc ::gui_file_finder_context_menu_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_file_finder_context_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset
}

proc ::gui_file_finder_context_menu_spec_test::asDict {kvList} {
    dict create {*}$kvList
}

proc ::gui_file_finder_context_menu_spec_test::menuAttrs {snapshot} {
    if {[llength $snapshot] < 4 || [lindex $snapshot 0] ne "menu"} {
        error "Invalid menu snapshot: $snapshot"
    }

    set attrs [dict create path [lindex $snapshot 1]]
    foreach {k v} [lrange $snapshot 2 end] {
        dict set attrs $k $v
    }
    return $attrs
}

proc ::gui_file_finder_context_menu_spec_test::entries {menuSnapshot} {
    set attrs [::gui_file_finder_context_menu_spec_test::menuAttrs $menuSnapshot]
    if {[dict get $attrs dynamic]} {
        return {}
    }
    return [dict get $attrs entries]
}

proc ::gui_file_finder_context_menu_spec_test::typeLabelPairs {menuSnapshot} {
    set out {}
    foreach entry [::gui_file_finder_context_menu_spec_test::entries $menuSnapshot] {
        set d [::gui_file_finder_context_menu_spec_test::asDict $entry]
        lappend out [list [dict get $d type] [dict get $d label]]
    }
    return $out
}

test gui-file-finder-context-menu-spec-structure-1.0 {File Finder context menu exposes stable actions for a file entry} -setup {
    ::gui_file_finder_context_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] file finder.tcl]

    set win .finder.t.text
    set fullPath [file join [pwd] "example.si4"]
    ::file::finder::contextMenu $win $fullPath 1 2 101 202

    set snapshot [::scid_test::menu_structure::snapshot ${win}.ctxtMenu]
    ::gui_file_finder_context_menu_spec_test::typeLabelPairs $snapshot
} -cleanup {
    ::gui_file_finder_context_menu_spec_test::cleanup
} -result {{command FinderCtxOpen} {command FinderCtxBackup} {command FinderCtxCopy} {command FinderCtxMove} {separator {}} {command FinderCtxDelete}}

cleanupTests

