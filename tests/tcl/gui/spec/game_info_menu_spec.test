package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_game_info_menu_spec_test {
    variable stubbedCommands {}
}

proc ::gui_game_info_menu_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_menu_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_game_info_menu_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::MB3 3
    set ::macOS 0

    # `main.tcl` executes `loadPlayersPhoto` at file scope, which requires Tk's
    # `image` command. Provide a minimal stub so the file can be sourced under
    # plain `tclsh`.
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        return
    }

    # Ensure the directories queried by loadPlayersPhoto exist so `glob -directory`
    # does not error.
    set _photosRoot [::scid_test::tempDir]
    foreach dirVar {::scidDataDir ::scidUserDir ::scidConfigDir ::scidShareDir} {
        set $dirVar $_photosRoot
    }
    file mkdir [file join $::scidShareDir photos]
    unset _photosRoot

    namespace eval ::htext {}

    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands ::htext::init {w} {
        return
    }

    # CreateGameInfo uses ttk labels for the player photos.
    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands ::ttk::label {path args} {
        if {![llength [info commands $path]]} {
            ::scid_test::widgets::defineWidget $path
        }
        return $path
    }

    # CreateGameInfo relies on autoscrollText to create `.main.gameInfo.text`.
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands autoscrollText {axis frame textWidget class} {
        if {![llength [info commands $textWidget]]} {
            ::scid_test::widgets::defineTextWidget $textWidget
        }
        return
    }

    # Force token-based labels (CreateGameInfo adds token labels then translates).
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }
    ::scid_test::mocks::stubCommand ::gui_game_info_menu_spec_test::stubbedCommands translateMenuLabels {menu} {
        return
    }
}

proc ::gui_game_info_menu_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_game_info_menu_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::MB3
}

proc ::gui_game_info_menu_spec_test::asDict {kvList} {
    dict create {*}$kvList
}

proc ::gui_game_info_menu_spec_test::menuAttrs {snapshot} {
    if {[llength $snapshot] < 4 || [lindex $snapshot 0] ne "menu"} {
        error "Invalid menu snapshot: $snapshot"
    }

    set attrs [dict create path [lindex $snapshot 1]]
    foreach {k v} [lrange $snapshot 2 end] {
        dict set attrs $k $v
    }
    return $attrs
}

proc ::gui_game_info_menu_spec_test::entries {menuSnapshot} {
    set attrs [::gui_game_info_menu_spec_test::menuAttrs $menuSnapshot]
    if {[dict get $attrs dynamic]} {
        return {}
    }
    return [dict get $attrs entries]
}

proc ::gui_game_info_menu_spec_test::typeLabelPairs {menuSnapshot} {
    set out {}
    foreach entry [::gui_game_info_menu_spec_test::entries $menuSnapshot] {
        set d [::gui_game_info_menu_spec_test::asDict $entry]
        lappend out [list [dict get $d type] [dict get $d label]]
    }
    return $out
}

test gui-game-info-menu-spec-structure-1.0 {Game-info context menu exposes stable toggles and delete action} -setup {
    ::gui_game_info_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    CreateGameInfo
    set snapshot [::scid_test::menu_structure::snapshot .main.gameInfo.menu]

    ::gui_game_info_menu_spec_test::typeLabelPairs $snapshot
} -cleanup {
    ::gui_game_info_menu_spec_test::cleanup
} -result {{checkbutton GInfoHideNext} {checkbutton GInfoMaterial} {checkbutton GInfoFEN} {checkbutton GInfoMarks} {checkbutton GInfoWrap} {checkbutton GInfoFullComment} {checkbutton GInfoPhotos} {separator {}} {command GInfoDelete}}

cleanupTests

