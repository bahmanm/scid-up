package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_gamelist_header_menu_spec_test {
    variable stubbedCommands {}
    variable treeColumnId
    variable treeColumnAnchor
    variable popupCalls {}
    variable removeColCalls {}
    variable sortCalls {}
    variable gridCalls {}
    variable forgetCalls {}
    variable focusCalls {}
    variable selectionCalls {}
    array set treeColumnId {}
    array set treeColumnAnchor {}
}

proc ::gui_gamelist_header_menu_spec_test::defineTreeview {path columnIdByColumnToken} {
    catch {rename $path ""}
    array unset ::gui_gamelist_header_menu_spec_test::treeColumnId "$path,*"
    array unset ::gui_gamelist_header_menu_spec_test::treeColumnAnchor "$path,*"
    foreach {colToken colId} $columnIdByColumnToken {
        set ::gui_gamelist_header_menu_spec_test::treeColumnId($path,$colToken) $colId
        set ::gui_gamelist_header_menu_spec_test::treeColumnAnchor($path,$colToken) w
    }
    interp alias {} $path {} ::gui_gamelist_header_menu_spec_test::dispatchTreeview $path
    return $path
}

proc ::gui_gamelist_header_menu_spec_test::dispatchTreeview {path subcmd args} {
    switch -- $subcmd {
        identify {
            set what [lindex $args 0]
            switch -- $what {
                region { return "heading" }
                column { return "#1" }
                default { error "treeview identify $what not stubbed" }
            }
        }
        column {
            set colToken [lindex $args 0]
            set opt [lindex $args 1]
            if {$opt ni {"-id" "-anchor"}} {
                error "treeview column $opt not stubbed"
            }
            if {![info exists ::gui_gamelist_header_menu_spec_test::treeColumnId($path,$colToken)]} {
                error "treeview $path missing column id for $colToken"
            }
            if {$opt eq "-id"} {
                return $::gui_gamelist_header_menu_spec_test::treeColumnId($path,$colToken)
            }
            if {[llength $args] == 2} {
                return $::gui_gamelist_header_menu_spec_test::treeColumnAnchor($path,$colToken)
            }
            set value [lindex $args 2]
            set ::gui_gamelist_header_menu_spec_test::treeColumnAnchor($path,$colToken) $value
            return
        }
        default {
            error "treeview $path subcommand $subcmd not stubbed"
        }
    }
}

proc ::gui_gamelist_header_menu_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_header_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset
    set ::gui_gamelist_header_menu_spec_test::popupCalls {}
    set ::gui_gamelist_header_menu_spec_test::removeColCalls {}
    set ::gui_gamelist_header_menu_spec_test::sortCalls {}
    set ::gui_gamelist_header_menu_spec_test::gridCalls {}
    set ::gui_gamelist_header_menu_spec_test::forgetCalls {}
    set ::gui_gamelist_header_menu_spec_test::focusCalls {}
    set ::gui_gamelist_header_menu_spec_test::selectionCalls {}

    ::scid_test::menu_capture::install ::gui_gamelist_header_menu_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::windows {}
    namespace eval ::windows::gamelist {}

    array set ::tr {
        GlistAlignL GlistAlignL
        GlistAlignR GlistAlignR
        GlistAlignC GlistAlignC
        GlistAddField GlistAddField
        GlistDeleteField GlistDeleteField
        ResetSort ResetSort
        FindBar FindBar
        Save Save
        Defaults Defaults
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            parent { return ".glistWin1" }
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            default { error "winfo $subcmd not stubbed in tests" }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands grid {args} {
        if {[lindex $args 0] eq "forget"} {
            lappend ::gui_gamelist_header_menu_spec_test::forgetCalls [lindex $args 1]
            return
        }
        lappend ::gui_gamelist_header_menu_spec_test::gridCalls $args
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands focus {w} {
        lappend ::gui_gamelist_header_menu_spec_test::focusCalls $w
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands tk_popup {menu x y} {
        lappend ::gui_gamelist_header_menu_spec_test::popupCalls [list $menu $x $y]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ni {"photo" "bitmap"}} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }
}

proc ::gui_gamelist_header_menu_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_header_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    foreach path [array names ::gui_gamelist_header_menu_spec_test::treeColumnId] {
        set tree [lindex [split $path ","] 0]
        catch {rename $tree ""}
    }
    array unset ::gui_gamelist_header_menu_spec_test::treeColumnId
    array set ::gui_gamelist_header_menu_spec_test::treeColumnId {}
    array unset ::gui_gamelist_header_menu_spec_test::treeColumnAnchor
    array set ::gui_gamelist_header_menu_spec_test::treeColumnAnchor {}

    unset -nocomplain ::tr
}

proc ::gui_gamelist_header_menu_spec_test::installRuntimeStubs {} {
    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands glist.removecol_ {w layout col} {
        lappend ::gui_gamelist_header_menu_spec_test::removeColCalls [list $w $layout $col]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands glist.sort_ {w idx layout clear} {
        lappend ::gui_gamelist_header_menu_spec_test::sortCalls [list $w $idx $layout $clear]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_header_menu_spec_test::stubbedCommands .glistWin1.find.text {subcmd args} {
        if {$subcmd eq "selection" && [lindex $args 0] eq "range"} {
            lappend ::gui_gamelist_header_menu_spec_test::selectionCalls [list .glistWin1.find.text [lindex $args 1] [lindex $args 2]]
            return
        }
        error ".glistWin1.find.text $subcmd not stubbed"
    }
}

proc ::gui_gamelist_header_menu_spec_test::hasLabel {menuSnapshot label} {
    expr {[catch {::scid_test::menu_spec::findEntryByLabel $menuSnapshot $label}]==0}
}

proc ::gui_gamelist_header_menu_spec_test::invokeMenuLabel {menuPath label} {
    foreach entry [::scid_test::menu_capture::entries $menuPath] {
        if {[dict get $entry -label] eq $label} {
            uplevel #0 [dict get $entry -command]
            return
        }
    }
    error "Menu $menuPath has no entry labelled: $label"
}

proc ::gui_gamelist_header_menu_spec_test::invokeCheckMenuLabel {menuPath label} {
    foreach entry [::scid_test::menu_capture::entries $menuPath] {
        if {[dict get $entry -label] ne $label} {
            continue
        }
        if {[dict get $entry type] ne "checkbutton"} {
            error "Menu entry $label in $menuPath is not a checkbutton"
        }
        set varName [dict get $entry -variable]
        upvar #0 $varName value
        set value [expr {![info exists value] || !$value}]
        uplevel #0 [dict get $entry -command]
        return
    }
    error "Menu $menuPath has no checkbutton labelled: $label"
}

test gui-gamelist-header-menu-spec-stable-actions-1.0 {Game list header menu exposes stable layout and findbar controls} -setup {
    ::gui_gamelist_header_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_spec_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0

    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot [::scid_test::menu_structure::snapshot ${w}.header_menu]

    list \
        [::gui_gamelist_header_menu_spec_test::hasLabel $snapshot ResetSort] \
        [::gui_gamelist_header_menu_spec_test::hasLabel $snapshot Layouts] \
        [::gui_gamelist_header_menu_spec_test::hasLabel $snapshot FindBar]
} -cleanup {
    ::gui_gamelist_header_menu_spec_test::cleanup
} -result {1 1 1}

test gui-gamelist-header-menu-spec-addfield-disabled-when-no-empty-cols-1.0 {Game list header AddField cascade is disabled when all columns are already present} -setup {
    ::gui_gamelist_header_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_spec_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0

    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot [::scid_test::menu_structure::snapshot ${w}.header_menu]

    ::scid_test::menu_spec::entryState $snapshot GlistAddField
} -cleanup {
    ::gui_gamelist_header_menu_spec_test::cleanup
} -result disabled

test gui-gamelist-header-menu-spec-actions-1.0 {Game list header actions keep callback wiring stable} -setup {
    ::gui_gamelist_header_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_spec_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0

    glist.popupmenu_ $w 1 1 100 200 $layout

    ::gui_gamelist_header_menu_spec_test::invokeMenuLabel ${w}.header_menu GlistAlignR
    ::gui_gamelist_header_menu_spec_test::invokeMenuLabel ${w}.header_menu GlistDeleteField
    ::gui_gamelist_header_menu_spec_test::invokeMenuLabel ${w}.header_menu ResetSort

    list \
        $::gui_gamelist_header_menu_spec_test::popupCalls \
        [$w column #1 -anchor] \
        [lindex $::glist_ColAnchor($layout) 0] \
        $::gui_gamelist_header_menu_spec_test::removeColCalls \
        $::gui_gamelist_header_menu_spec_test::sortCalls
} -cleanup {
    ::gui_gamelist_header_menu_spec_test::cleanup
} -result {{{.glistWin1.games.glist.header_menu 100 200}} e e {{.glistWin1.games.glist Full #1}} {{.glistWin1.games.glist 0 Full 1}}}

test gui-gamelist-header-menu-spec-findbar-1.0 {Game list header FindBar checkbutton keeps show-hide wiring stable} -setup {
    ::gui_gamelist_header_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_header_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_header_menu_spec_test::defineTreeview $w [list "#1" "GlistWhite"]

    menu ${w}.header_menu
    menu ${w}.header_menu.addcol

    set layout Full
    set ::glist_FindBar($layout) 0
    set ::glistFindBar($w) .glistWin1.find

    glist.popupmenu_ $w 1 1 100 200 $layout

    ::gui_gamelist_header_menu_spec_test::invokeCheckMenuLabel ${w}.header_menu FindBar
    ::gui_gamelist_header_menu_spec_test::invokeCheckMenuLabel ${w}.header_menu FindBar

    list \
        $::gui_gamelist_header_menu_spec_test::popupCalls \
        $::gui_gamelist_header_menu_spec_test::gridCalls \
        $::gui_gamelist_header_menu_spec_test::focusCalls \
        $::gui_gamelist_header_menu_spec_test::selectionCalls \
        $::gui_gamelist_header_menu_spec_test::forgetCalls \
        $::glist_FindBar($layout)
} -cleanup {
    ::gui_gamelist_header_menu_spec_test::cleanup
} -result {{{.glistWin1.games.glist.header_menu 100 200}} {{.glistWin1.find -row 0 -columnspan 2 -sticky news}} {.glistWin1.find.text .glistWin1.games.glist} {{.glistWin1.find.text 0 end}} .glistWin1.find 0}

cleanupTests
