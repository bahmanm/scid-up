package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_gamelist_row_menu_spec_test {
    variable stubbedCommands {}
    variable selected "42_0"
    variable baseCurrent 1
    variable baseForWidget 1
    variable gameNumber 1
    variable eventCalls {}
    variable popupCalls {}
    variable switchBaseCalls {}
    variable loadCalls {}
    variable browseCalls {}
    variable delflagCalls {}
    variable removeFromFilterCalls {}
    variable findCurrentCalls {}
}

proc ::gui_gamelist_row_menu_spec_test::defineTreeview {path} {
    catch {rename $path ""}
    interp alias {} $path {} ::gui_gamelist_row_menu_spec_test::dispatchTreeview $path
    return $path
}

proc ::gui_gamelist_row_menu_spec_test::dispatchTreeview {path subcmd args} {
    switch -- $subcmd {
        identify {
            set what [lindex $args 0]
            switch -- $what {
                region { return "cell" }
                default { error "treeview identify $what not stubbed" }
            }
        }
        selection {
            if {[llength $args]} {
                set op [lindex $args 0]
                if {$op eq "set"} {
                    set ::gui_gamelist_row_menu_spec_test::selected [lindex $args 1]
                    return
                }
                error "treeview selection $op not stubbed"
            }
            return $::gui_gamelist_row_menu_spec_test::selected
        }
        default {
            error "treeview $path subcommand $subcmd not stubbed"
        }
    }
}

proc ::gui_gamelist_row_menu_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_row_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_gamelist_row_menu_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    namespace eval ::windows {}
    namespace eval ::windows::gamelist {}
    namespace eval ::file {}
    namespace eval ::notify {}
    namespace eval ::game {}

    set ::gui_gamelist_row_menu_spec_test::selected "42_0"
    set ::gui_gamelist_row_menu_spec_test::baseCurrent 1
    set ::gui_gamelist_row_menu_spec_test::baseForWidget 1
    set ::gui_gamelist_row_menu_spec_test::gameNumber 1
    set ::gui_gamelist_row_menu_spec_test::eventCalls {}
    set ::gui_gamelist_row_menu_spec_test::popupCalls {}
    set ::gui_gamelist_row_menu_spec_test::switchBaseCalls {}
    set ::gui_gamelist_row_menu_spec_test::loadCalls {}
    set ::gui_gamelist_row_menu_spec_test::browseCalls {}
    set ::gui_gamelist_row_menu_spec_test::delflagCalls {}
    set ::gui_gamelist_row_menu_spec_test::removeFromFilterCalls {}
    set ::gui_gamelist_row_menu_spec_test::findCurrentCalls {}

    array set ::tr {
        LoadGame LoadGame
        BrowseGame BrowseGame
        MergeGame MergeGame
        GlistMergeGameInBase GlistMergeGameInBase
        CopyGameTo CopyGameTo
        DeleteGame DeleteGame
        UndeleteGame UndeleteGame
        Filter Filter
        SearchReset SearchReset
        SearchNegate SearchNegate
        GlistRemoveGameAndAboveFromFilter GlistRemoveGameAndAboveFromFilter
        GlistRemoveThisGameFromFilter GlistRemoveThisGameFromFilter
        GlistRemoveGameAndBelowFromFilter GlistRemoveGameAndBelowFromFilter
        GlistDeleteAllGames GlistDeleteAllGames
        GlistUndeleteAllGames GlistUndeleteAllGames
        ToolsExpFilter ToolsExpFilter
        CopyGames CopyGames
        FindBar FindBar
        FindCurrentGame FindCurrentGame
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands tk_popup {menu x y} {
        lappend ::gui_gamelist_row_menu_spec_test::popupCalls [list $menu $x $y]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands event {subcmd args} {
        if {$subcmd ne "generate"} {
            error "event $subcmd not stubbed in tests"
        }
        lappend ::gui_gamelist_row_menu_spec_test::eventCalls [list $subcmd {*}$args]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            parent { return ".glistWin1.games" }
            default { error "winfo $subcmd not stubbed in tests" }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands sc_game {subcmd args} {
        if {$subcmd ne "number"} {
            error "sc_game $subcmd not stubbed in tests"
        }
        return $::gui_gamelist_row_menu_spec_test::gameNumber
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands sc_base {subcmd args} {
        switch -- $subcmd {
            current { return $::gui_gamelist_row_menu_spec_test::baseCurrent }
            gameflag {
                # `sc_base gameflag <base> <idx> get del` queried for Delete/Undelete label
                # Default to "not deleted".
                return 0
            }
            list { return {} }
            isReadOnly { return 0 }
            default {
                error "sc_base $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands ::file::SwitchToBase {base {arg 0}} {
        lappend ::gui_gamelist_row_menu_spec_test::switchBaseCalls [list $base $arg]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands ::game::Load {idx {ply ""}} {
        lappend ::gui_gamelist_row_menu_spec_test::loadCalls [list $idx $ply]
        return
    }
    namespace eval ::gbrowser {}
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands ::gbrowser::new {base idx ply} {
        lappend ::gui_gamelist_row_menu_spec_test::browseCalls [list $base $idx $ply]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ni {"photo" "bitmap"}} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }
}

proc ::gui_gamelist_row_menu_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_gamelist_row_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
}

proc ::gui_gamelist_row_menu_spec_test::installRuntimeStubs {} {
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands glist.delflag_ {w idx} {
        lappend ::gui_gamelist_row_menu_spec_test::delflagCalls [list $w $idx]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands glist.removeFromFilter_ {w idx {dir ""}} {
        lappend ::gui_gamelist_row_menu_spec_test::removeFromFilterCalls [list $w $idx $dir]
        return
    }
    ::scid_test::mocks::stubCommand ::gui_gamelist_row_menu_spec_test::stubbedCommands glist.findcurrentgame_ {w gnum} {
        lappend ::gui_gamelist_row_menu_spec_test::findCurrentCalls [list $w $gnum]
        return
    }
}

proc ::gui_gamelist_row_menu_spec_test::invokeMenuLabel {menuPath label} {
    foreach entry [::scid_test::menu_capture::entries $menuPath] {
        if {[dict get $entry -label] eq $label} {
            uplevel #0 [dict get $entry -command]
            return
        }
    }
    error "Menu $menuPath has no entry labelled: $label"
}

test gui-gamelist-row-menu-spec-find-current-game-gating-1.0 {Game list row menu disables FindCurrentGame when not in current base or no current game} -setup {
    ::gui_gamelist_row_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_row_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_row_menu_spec_test::defineTreeview $w

    menu ${w}.game_menu

    set layout Full
    set ::glistBase($w) 2
    set ::glistFilter($w) dbfilter
    set ::glist_FindBar($layout) 0

    set ::gui_gamelist_row_menu_spec_test::baseCurrent 1
    set ::gui_gamelist_row_menu_spec_test::gameNumber 1
    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot0 [::scid_test::menu_structure::snapshot ${w}.game_menu]

    set ::glistBase($w) 1
    set ::gui_gamelist_row_menu_spec_test::baseCurrent 1
    set ::gui_gamelist_row_menu_spec_test::gameNumber 0
    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot1 [::scid_test::menu_structure::snapshot ${w}.game_menu]

    set ::glistBase($w) 1
    set ::gui_gamelist_row_menu_spec_test::baseCurrent 1
    set ::gui_gamelist_row_menu_spec_test::gameNumber 7
    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot2 [::scid_test::menu_structure::snapshot ${w}.game_menu]

    list \
        [::scid_test::menu_spec::entryState $snapshot0 FindCurrentGame] \
        [::scid_test::menu_spec::entryState $snapshot1 FindCurrentGame] \
        [::scid_test::menu_spec::entryState $snapshot2 FindCurrentGame]
} -cleanup {
    ::gui_gamelist_row_menu_spec_test::cleanup
} -result {disabled disabled normal}

test gui-gamelist-row-menu-spec-actions-1.0 {Game list row menu actions keep callback wiring and popup behavior stable} -setup {
    ::gui_gamelist_row_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::gui_gamelist_row_menu_spec_test::installRuntimeStubs

    set w .glistWin1.games.glist
    ::gui_gamelist_row_menu_spec_test::defineTreeview $w

    menu ${w}.game_menu

    set layout Full
    set ::glistBase($w) 1
    set ::glistFilter($w) dbfilter
    set ::glist_FindBar($layout) 0
    set ::gui_gamelist_row_menu_spec_test::gameNumber 7

    glist.popupmenu_ $w 1 1 100 200 $layout
    set snapshot [::scid_test::menu_structure::snapshot ${w}.game_menu]
    set filterMenu ${w}.game_menu.filter

    ::gui_gamelist_row_menu_spec_test::invokeMenuLabel ${w}.game_menu LoadGame
    ::gui_gamelist_row_menu_spec_test::invokeMenuLabel ${w}.game_menu BrowseGame
    ::gui_gamelist_row_menu_spec_test::invokeMenuLabel ${w}.game_menu DeleteGame
    ::gui_gamelist_row_menu_spec_test::invokeMenuLabel $filterMenu GlistRemoveThisGameFromFilter
    ::gui_gamelist_row_menu_spec_test::invokeMenuLabel ${w}.game_menu FindCurrentGame

    list \
        $::gui_gamelist_row_menu_spec_test::eventCalls \
        $::gui_gamelist_row_menu_spec_test::popupCalls \
        $::gui_gamelist_row_menu_spec_test::switchBaseCalls \
        $::gui_gamelist_row_menu_spec_test::loadCalls \
        $::gui_gamelist_row_menu_spec_test::browseCalls \
        $::gui_gamelist_row_menu_spec_test::delflagCalls \
        $::gui_gamelist_row_menu_spec_test::selected \
        [::scid_test::menu_spec::entryState $snapshot FindCurrentGame] \
        $::gui_gamelist_row_menu_spec_test::removeFromFilterCalls \
        $::gui_gamelist_row_menu_spec_test::findCurrentCalls
} -cleanup {
    ::gui_gamelist_row_menu_spec_test::cleanup
} -result {{{generate .glistWin1.games.glist <ButtonPress-1> -x 1 -y 1}} {{.glistWin1.games.glist.game_menu 100 200}} {{1 0}} {{42 0}} {{1 42 0}} {{.glistWin1.games.glist 42}} {} normal {{.glistWin1.games.glist 42 {}}} {{.glistWin1.games.glist 7}}}

cleanupTests
