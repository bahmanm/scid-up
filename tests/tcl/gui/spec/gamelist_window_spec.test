test gui-gamelist-window-spec-setbase-1.0 {Game list window base switches preserve refresh scheduling and positional-filter teardown semantics} -setup {
    ::gui_gamelist_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    ::scid_test::gui_fixtures::gamelist_window::installRefreshRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    set ::gamelistFilter(.glistWin1) dbfilter+tree
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls

    ::windows::gamelist::SetBase .glistWin1 2 newfilter
    set regularResult [list \
        [::scid_test::gui_fixtures::gamelist_window::afterCalls] \
        $::gamelistBase(.glistWin1) \
        $::gamelistFilter(.glistWin1) \
        [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls] \
        [::scid_test::gui_fixtures::gamelist_window::titleCalls] \
        [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls]]

    set ::gamelistMenu(.glistWin1) stats
    set ::gamelistPosMask(.glistWin1) 1
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls

    ::windows::gamelist::SetBase .glistWin1 3 dbfilter+tree

    list \
        $regularResult \
        [::scid_test::gui_fixtures::gamelist_window::afterCalls] \
        $::gamelistBase(.glistWin1) \
        $::gamelistFilter(.glistWin1) \
        $::gamelistPosMask(.glistWin1) \
        $::gamelistMenu(.glistWin1) \
        [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls] \
        [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls] \
        [::scid_test::gui_fixtures::gamelist_window::updateTreeFilterCalls] \
        [::scid_test::gui_fixtures::gamelist_window::cancelUpdateTreeFilterCalls] \
        [::scid_test::gui_fixtures::gamelist_window::notifyFilterCalls] \
        [::scid_test::widgets::getState .glistWin1.buttons.boardFilter widget.states]
} -cleanup {
    ::gui_gamelist_window_spec_test::cleanup
} -result {{{{idle {::windows::gamelist::filterRelease_ 1 dbfilter+tree}}} 2 newfilter {{.glistWin1.games 2 newfilter 1}} {{.glistWin1 { base2 (3 / 10)}}} .glistWin1} {{idle {::windows::gamelist::filterRelease_ 2 newfilter}}} 3 dbfilter 0 {} {} {} {} {{.glistWin1.progress 100 100}} {{3 dbfilter}} {}}

test gui-gamelist-window-spec-refresh-1.0 {Game list window refresh updates active windows and reroutes stale ones to the current base} -setup {
    ::gui_gamelist_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    ::windows::gamelist::Open 2 dbfilter
    ::scid_test::gui_fixtures::gamelist_window::installRefreshDispatchStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::scid_test::gui_fixtures::gamelist_window::setCurrentBase 3
    ::scid_test::gui_fixtures::gamelist_window::setBaseInUse 1 1
    ::scid_test::gui_fixtures::gamelist_window::setBaseInUse 2 0
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls

    ::windows::gamelist::Refresh 7

    list \
        [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls] \
        [::scid_test::gui_fixtures::gamelist_window::titleCalls] \
        [::scid_test::gui_fixtures::gamelist_window::setBaseCalls]
} -cleanup {
    ::gui_gamelist_window_spec_test::cleanup
} -result {{{.glistWin1.games 1 dbfilter 7}} {{.glistWin1 { base1 (3 / 10)}}} {{.glistWin2 3 dbfilter}}}

test gui-gamelist-window-spec-filter-export-1.0 {Game list window export keeps save-dialog, extension, and error handling stable} -setup {
    ::gui_gamelist_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    set ::glistSortStr(.glistWin1.games.glist) W+

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    set saveDialog [::gui_gamelist_window_spec_test::asDict [lindex [::scid_test::gui_fixtures::gamelist_window::saveFileCalls] 0]]
    set pgnResult [list \
        [dict get $saveDialog -initialdir] \
        [dict get $saveDialog -typevariable] \
        [dict get $saveDialog -title] \
        [::scid_test::gui_fixtures::gamelist_window::progressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::filterExportCalls] \
        [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]

    set ::gamelistExport LaTeX
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export-tex
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    set latexResult [list \
        [::scid_test::gui_fixtures::gamelist_window::progressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::filterExportCalls] \
        [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse ""
    ::scid_test::gui_fixtures::gamelist_window::resetExportCalls
    ::windows::gamelist::FilterExport .glistWin1
    set cancelSaveDialog [::gui_gamelist_window_spec_test::asDict [lindex [::scid_test::gui_fixtures::gamelist_window::saveFileCalls] 0]]
    set cancelResult [list \
        [dict get $cancelSaveDialog -initialdir] \
        [dict get $cancelSaveDialog -typevariable] \
        [dict get $cancelSaveDialog -title] \
        [::scid_test::gui_fixtures::gamelist_window::progressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::filterExportCalls] \
        [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls]]

    set ::gamelistExport PGN
    ::scid_test::gui_fixtures::gamelist_window::setSaveFileResponse /tmp/filter-export-error
    ::scid_test::gui_fixtures::gamelist_window::setExportError export-failed NOT_USER_CANCEL
    ::windows::gamelist::FilterExport .glistWin1
    set errorResult [list \
        [::scid_test::gui_fixtures::gamelist_window::filterExportCalls] \
        [::scid_test::gui_fixtures::gamelist_window::closeProgressCalls] \
        [::scid_test::gui_fixtures::gamelist_window::errorMessageBoxCalls]]

    list $pgnResult $latexResult $cancelResult $errorResult
} -cleanup {
    ::gui_gamelist_window_spec_test::cleanup
} -result {{/tmp/scid-base ::gamelistExport ToolsExpFilter {{ScidUp {Exporting games...} Cancel}} {{1 dbfilter W+ /tmp/filter-export.pgn PGN}} 1 {}} {{{ScidUp {Exporting games...} Cancel}} {{1 dbfilter W+ /tmp/filter-export-tex.tex LaTeX latex-start latex-end}} 1 {}} {/tmp/scid-base ::gamelistExport ToolsExpFilter {} {} 0} {{{1 dbfilter W+ /tmp/filter-export-error.pgn PGN}} 1 {{}}}}

test gui-gamelist-window-spec-list-tree-bases-1.0 {Game list window listTreeBases keeps busy-state updates and base filtering stable} -setup {
    ::gui_gamelist_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    ::windows::gamelist::Open 2 dbfilter

    set ::gamelistPosMask(.glistWin1) 1
    set ::gamelistFilter(.glistWin1) dbfilter+tree
    set ::gamelistPosMask(.glistWin2) 1
    set ::gamelistFilter(.glistWin2) second+tree

    set tagCalls1Before [llength [::scid_test::widgets::getTagConfigureCalls .glistWin1.games.glist]]
    set tagCalls2Before [llength [::scid_test::widgets::getTagConfigureCalls .glistWin2.games.glist]]
    set allResult [::windows::gamelist::listTreeBases]
    set allTagCalls1 [::gui_gamelist_window_spec_test::listTailFrom [::scid_test::widgets::getTagConfigureCalls .glistWin1.games.glist] $tagCalls1Before]
    set allTagCalls2 [::gui_gamelist_window_spec_test::listTailFrom [::scid_test::widgets::getTagConfigureCalls .glistWin2.games.glist] $tagCalls2Before]
    set allImage1 [::scid_test::widgets::getState .glistWin1.buttons.boardFilter -image]
    set allImage2 [::scid_test::widgets::getState .glistWin2.buttons.boardFilter -image]

    .glistWin1.buttons.boardFilter configure -image tb_BoardMask
    .glistWin2.buttons.boardFilter configure -image tb_BoardMask
    set tagCalls1Before [llength [::scid_test::widgets::getTagConfigureCalls .glistWin1.games.glist]]
    set tagCalls2Before [llength [::scid_test::widgets::getTagConfigureCalls .glistWin2.games.glist]]
    set constrainedResult [::windows::gamelist::listTreeBases 2]
    set constrainedTagCalls1 [::gui_gamelist_window_spec_test::listTailFrom [::scid_test::widgets::getTagConfigureCalls .glistWin1.games.glist] $tagCalls1Before]
    set constrainedTagCalls2 [::gui_gamelist_window_spec_test::listTailFrom [::scid_test::widgets::getTagConfigureCalls .glistWin2.games.glist] $tagCalls2Before]
    set constrainedImage1 [::scid_test::widgets::getState .glistWin1.buttons.boardFilter -image]
    set constrainedImage2 [::scid_test::widgets::getState .glistWin2.buttons.boardFilter -image]

    list \
        $allResult \
        $allTagCalls1 \
        $allTagCalls2 \
        $allImage1 \
        $allImage2 \
        $constrainedResult \
        $constrainedTagCalls1 \
        $constrainedTagCalls2 \
        $constrainedImage1 \
        $constrainedImage2
} -cleanup {
    ::gui_gamelist_window_spec_test::cleanup
} -result {{{1 dbfilter+tree {.glistWin1.progress 100 100}} {2 second+tree {.glistWin2.progress 100 100}}} {{fsmall -foreground #bababa}} {{fsmall -foreground #bababa}} tb_BoardMaskBusy tb_BoardMaskBusy {{2 second+tree {.glistWin2.progress 100 100}}} {} {{fsmall -foreground #bababa}} tb_BoardMask tb_BoardMaskBusy}

cleanupTests
