test gui-gamelist-window-spec-database-modified-1.0 {Game list window refresh dispatch stays stable across full and component filter updates} -setup {
    ::gui_gamelist_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows gamelist.tcl]
    ::scid_test::gui_fixtures::gamelist_window::installRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    ::windows::gamelist::Open 1 dbfilter
    ::windows::gamelist::Open 2 dbfilter
    ::scid_test::gui_fixtures::gamelist_window::installRefreshRuntimeStubs ::gui_gamelist_window_spec_test::stubbedCommands

    set ::gamelistFilter(.glistWin1) dbfilter+tree
    ::scid_test::gui_fixtures::gamelist_window::resetRefreshCalls

    ::windows::gamelist::DatabaseModified 1
    ::windows::gamelist::DatabaseModified 1 tree
    ::windows::gamelist::DatabaseModified 2 dbfilter
    ::windows::gamelist::DatabaseModified 2 other

    list \
        [::scid_test::gui_fixtures::gamelist_window::glistUpdateCalls] \
        [::scid_test::gui_fixtures::gamelist_window::titleCalls] \
        [::scid_test::gui_fixtures::gamelist_window::updateStatsCalls]
