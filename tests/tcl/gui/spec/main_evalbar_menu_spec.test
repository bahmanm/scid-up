package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_main_evalbar_menu_spec_test {
    variable stubbedCommands {}
    variable enginesList {}
    variable engineNames {}
}

proc ::gui_main_evalbar_menu_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_main_evalbar_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_main_evalbar_menu_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 1

    set ::macOS 0

    # `main.tcl` sources `loadPlayersPhoto` at file scope, which requires Tk's
    # `image` command and expected directory variables.
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        return
    }

    set _photosRoot [::scid_test::tempDir]
    foreach dirVar {::scidDataDir ::scidUserDir ::scidConfigDir ::scidShareDir} {
        set $dirVar $_photosRoot
    }
    file mkdir [file join $::scidShareDir photos]
    unset _photosRoot

    namespace eval ::board {}
    namespace eval ::board::mark {}
    namespace eval ::enginewin {}
    namespace eval ::enginecfg {}

    # Force token-based labels.
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands tr {tag {lang ""}} {
        return $tag
    }

    # `createMainEvalBarMenu` uses `winfo exists`/`destroy` for menu recycling.
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    set ::gui_main_evalbar_menu_spec_test::enginesList {}
    set ::gui_main_evalbar_menu_spec_test::engineNames {}

    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands ::enginewin::listEngines {} {
        return $::gui_main_evalbar_menu_spec_test::enginesList
    }
    ::scid_test::mocks::stubCommand ::gui_main_evalbar_menu_spec_test::stubbedCommands ::enginecfg::names {} {
        return $::gui_main_evalbar_menu_spec_test::engineNames
    }
}

proc ::gui_main_evalbar_menu_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_main_evalbar_menu_spec_test::stubbedCommands
    ::scid_test::menu_capture::reset

    unset -nocomplain ::mainEvalBarEngineID_
    unset -nocomplain ::mainEvalBarCheckbutton
    unset -nocomplain ::showMainEvalBarArrow
}

proc ::gui_main_evalbar_menu_spec_test::asDict {kvList} {
    dict create {*}$kvList
}

proc ::gui_main_evalbar_menu_spec_test::menuAttrs {snapshot} {
    if {[llength $snapshot] < 4 || [lindex $snapshot 0] ne "menu"} {
        error "Invalid menu snapshot: $snapshot"
    }

    set attrs [dict create path [lindex $snapshot 1]]
    foreach {k v} [lrange $snapshot 2 end] {
        dict set attrs $k $v
    }
    return $attrs
}

proc ::gui_main_evalbar_menu_spec_test::entries {menuSnapshot} {
    set attrs [::gui_main_evalbar_menu_spec_test::menuAttrs $menuSnapshot]
    if {[dict get $attrs dynamic]} {
        return {}
    }
    return [dict get $attrs entries]
}

proc ::gui_main_evalbar_menu_spec_test::typeLabelPairs {menuSnapshot} {
    set out {}
    foreach entry [::gui_main_evalbar_menu_spec_test::entries $menuSnapshot] {
        set d [::gui_main_evalbar_menu_spec_test::asDict $entry]
        lappend out [list [dict get $d type] [dict get $d label]]
    }
    return $out
}

test gui-main-evalbar-menu-spec-selected-running-engine-is-checkbutton-1.0 {Eval bar menu shows the selected running engine as a checkbutton and keeps stable tail items} -setup {
    ::gui_main_evalbar_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    set ::gui_main_evalbar_menu_spec_test::enginesList [list \
        [list 1 Stockfish 1] \
        [list 2 Leela 1] \
        [list 3 Ethereal 0] \
    ]
    set ::gui_main_evalbar_menu_spec_test::engineNames {Stockfish Leela Komodo}

    set ::mainEvalBarEngineID_ 1
    set ::showMainEvalBarArrow 1

    ::createMainEvalBarMenu .main.board
    set snapshot [::scid_test::menu_structure::snapshot .main.board.evalbar_menu]

    ::gui_main_evalbar_menu_spec_test::typeLabelPairs $snapshot
} -cleanup {
    ::gui_main_evalbar_menu_spec_test::cleanup
} -result {{checkbutton Stockfish} {command Leela} {separator {}} {command Ethereal} {command Komodo} {command NewLocalEngine} {separator {}} {checkbutton BestMoveArrow} {separator {}} {command Hide}}

test gui-main-evalbar-menu-spec-no-selected-engine-yields-only-commands-1.0 {Eval bar menu uses commands when no selected engine exists} -setup {
    ::gui_main_evalbar_menu_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] main.tcl]

    set ::gui_main_evalbar_menu_spec_test::enginesList [list \
        [list 1 Stockfish 1] \
        [list 2 Leela 1] \
    ]
    set ::gui_main_evalbar_menu_spec_test::engineNames {Stockfish Leela}

    unset -nocomplain ::mainEvalBarEngineID_
    set ::showMainEvalBarArrow 1

    ::createMainEvalBarMenu .main.board
    set snapshot [::scid_test::menu_structure::snapshot .main.board.evalbar_menu]

    lrange [::gui_main_evalbar_menu_spec_test::typeLabelPairs $snapshot] 0 1
} -cleanup {
    ::gui_main_evalbar_menu_spec_test::cleanup
} -result {{command Stockfish} {command Leela}}

cleanupTests
