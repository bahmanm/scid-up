package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_preferences_window_spec_test {
    variable stubbedCommands {}
    variable bindCalls {}
    variable focusCalls {}
    variable winCreateCalls {}
    variable initCalls {}

    variable treeviewState
    array set treeviewState {}

    variable treeviewInserted
    array set treeviewInserted {}

    variable treeviewSelection
    array set treeviewSelection {}

    variable canvasState
    array set canvasState {}

    variable canvasCreateCalls
    array set canvasCreateCalls {}
}

proc ::gui_preferences_window_spec_test::defineTreeview {path} {
    catch {rename $path ""}
    interp alias {} $path {} ::gui_preferences_window_spec_test::dispatchTreeview $path
    return $path
}

proc ::gui_preferences_window_spec_test::dispatchTreeview {path subcmd args} {
    switch -- $subcmd {
        configure {
            if {[llength $args] % 2 != 0} {
                error "treeview $path configure expects option/value pairs, got: $args"
            }
            foreach {opt val} $args {
                set ::gui_preferences_window_spec_test::treeviewState($path,$opt) $val
            }
            return
        }
        cget {
            set opt [lindex $args 0]
            if {![info exists ::gui_preferences_window_spec_test::treeviewState($path,$opt)]} {
                error "treeview $path missing option $opt"
            }
            return $::gui_preferences_window_spec_test::treeviewState($path,$opt)
        }
        insert {
            # insert <parent> <index> ?option value ...?
            set parent [lindex $args 0]
            set index [lindex $args 1]
            set opts [lrange $args 2 end]

            set itemId ""
            set values {}
            for {set i 0} {$i < [llength $opts]} {incr i 2} {
                set opt [lindex $opts $i]
                set val [lindex $opts [expr {$i + 1}]]
                if {$opt eq "-id"} { set itemId $val }
                if {$opt eq "-values"} { set values $val }
            }
            if {$itemId eq ""} {
                error "treeview $path insert missing -id (parent=$parent index=$index opts=$opts)"
            }

            lappend ::gui_preferences_window_spec_test::treeviewInserted($path) [list \
                -parent $parent \
                -index $index \
                -id $itemId \
                -values $values \
            ]
            return $itemId
        }
        column {
            # column <col> ?option value ...?
            set col [lindex $args 0]
            set opts [lrange $args 1 end]
            if {[llength $opts] % 2 != 0} {
                error "treeview $path column expects option/value pairs, got: $opts"
            }
            foreach {opt val} $opts {
                set ::gui_preferences_window_spec_test::treeviewState($path,column,$col,$opt) $val
            }
            return
        }
        selection {
            if {![llength $args]} {
                if {![info exists ::gui_preferences_window_spec_test::treeviewSelection($path)]} {
                    return ""
                }
                return $::gui_preferences_window_spec_test::treeviewSelection($path)
            }

            set op [lindex $args 0]
            switch -- $op {
                set {
                    set ids [lrange $args 1 end]
                    set ::gui_preferences_window_spec_test::treeviewSelection($path) $ids
                    return
                }
                default {
                    error "treeview $path selection $op not stubbed"
                }
            }
        }
        default {
            error "treeview $path subcommand $subcmd not stubbed"
        }
    }
}

proc ::gui_preferences_window_spec_test::defineCanvas {path} {
    catch {rename $path ""}
    interp alias {} $path {} ::gui_preferences_window_spec_test::dispatchCanvas $path
    return $path
}

proc ::gui_preferences_window_spec_test::dispatchCanvas {path subcmd args} {
    switch -- $subcmd {
        configure {
            if {[llength $args] % 2 != 0} {
                error "canvas $path configure expects option/value pairs, got: $args"
            }
            foreach {opt val} $args {
                set ::gui_preferences_window_spec_test::canvasState($path,$opt) $val
            }
            return
        }
        cget {
            set opt [lindex $args 0]
            if {![info exists ::gui_preferences_window_spec_test::canvasState($path,$opt)]} {
                error "canvas $path missing option $opt"
            }
            return $::gui_preferences_window_spec_test::canvasState($path,$opt)
        }
        create {
            set type [lindex $args 0]
            if {$type ne "window"} {
                return 0
            }
            lappend ::gui_preferences_window_spec_test::canvasCreateCalls($path) $args
            return [llength $::gui_preferences_window_spec_test::canvasCreateCalls($path)]
        }
        xview -
        yview {
            return
        }
        default {
            error "canvas $path subcommand $subcmd not stubbed"
        }
    }
}

proc ::gui_preferences_window_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_preferences_window_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    set ::language E
    array set ::menuLabel {E,ConfigureScid ConfigureScid}

    array set ::tr {
        OptionsBoard OptionsBoard
        OptionsFonts OptionsFonts
        OptionsToolbar OptionsToolbar
        OptionsInternationalization OptionsInternationalization
        OptionsRecent OptionsRecent
        OptionsSounds OptionsSounds
        OptionsMoves OptionsMoves
        ConfigureInformant ConfigureInformant
    }

    namespace eval ::win {}
    namespace eval ::preferences {}
    namespace eval ::recentFiles {}
    namespace eval ::utils {}
    namespace eval ::utils::sound {}

    set ::gui_preferences_window_spec_test::bindCalls {}
    set ::gui_preferences_window_spec_test::focusCalls {}
    set ::gui_preferences_window_spec_test::winCreateCalls {}
    set ::gui_preferences_window_spec_test::initCalls {}

    array unset ::gui_preferences_window_spec_test::treeviewState
    array set ::gui_preferences_window_spec_test::treeviewState {}
    array unset ::gui_preferences_window_spec_test::treeviewInserted
    array set ::gui_preferences_window_spec_test::treeviewInserted {}
    array unset ::gui_preferences_window_spec_test::treeviewSelection
    array set ::gui_preferences_window_spec_test::treeviewSelection {}
    array unset ::gui_preferences_window_spec_test::canvasState
    array set ::gui_preferences_window_spec_test::canvasState {}
    array unset ::gui_preferences_window_spec_test::canvasCreateCalls
    array set ::gui_preferences_window_spec_test::canvasCreateCalls {}

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands tr {tag {lang ""}} {
        if {[info exists ::tr($tag)]} { return $::tr($tag) }
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands winfo {subcmd args} {
        switch -- $subcmd {
            exists {
                set w [lindex $args 0]
                expr {[llength [info commands $w]] > 0}
            }
            reqwidth -
            reqheight {
                return 100
            }
            default {
                error "winfo $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands bind {w seq script} {
        lappend ::gui_preferences_window_spec_test::bindCalls [list $w $seq $script]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands focus {w} {
        lappend ::gui_preferences_window_spec_test::focusCalls $w
        return
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands grid {args} { return }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands autoscrollBars {args} { return }
    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands ::applyThemeColor_background {args} { return }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands ::win::createWindow {w title} {
        lappend ::gui_preferences_window_spec_test::winCreateCalls [list $w $title]
        if {[llength [info commands $w]]} {
            return 0
        }
        ::scid_test::widgets::defineWidget $w
        return 1
    }
    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands ::win::makeVisible {w} { return }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands ::ttk::frame {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }
    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands ::ttk::treeview {path args} {
        ::gui_preferences_window_spec_test::defineTreeview $path
        if {[llength $args]} {
            $path configure {*}$args
        }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands canvas {path args} {
        ::gui_preferences_window_spec_test::defineCanvas $path
        if {[llength $args]} {
            $path configure {*}$args
        }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands font {subcmd args} {
        if {$subcmd eq "measure"} {
            # `font measure font_Regular <text>` -> return a stable pixel-like width.
            set text [lindex $args 1]
            return [expr {[string length $text] * 8}]
        }

        if {$subcmd eq "create"} {
            set name "scid_test_font"
            if {[llength $args] > 0 && ![string match "-*" [lindex $args 0]]} {
                set name [lindex $args 0]
            }
            return $name
        }

        return "scid_test_font"
    }
}

proc ::gui_preferences_window_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_preferences_window_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::tr
    unset -nocomplain ::menuLabel
    unset -nocomplain ::language
}

test gui-preferences-window-spec-skeleton-1.0 {Preferences window creates the option list, config canvas, and invokes each config pane initialiser} -setup {
    ::gui_preferences_window_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows preferences.tcl]

    foreach initProc {
        chooseBoardColors
        ::preferences::fonts
        ConfigToolbar
        ::preferences::internationalization
        ::recentFiles::configure
        ::utils::sound::OptionsDialog
        ::preferences::moves
        configInformant
    } {
        set body [string map [list @P@ $initProc] {
            lappend ::gui_preferences_window_spec_test::initCalls [list @P@ $frame]
            return
        }]
        ::scid_test::mocks::stubCommand ::gui_preferences_window_spec_test::stubbedCommands $initProc {frame} $body
    }

    ::preferences::Open

    foreach p {.preferences .preferences.options .preferences.options.list .preferences.config .preferences.c .preferences.c.f} {
        if {![llength [info commands $p]]} {
            error "Expected widget command to exist: $p"
        }
    }

    if {![info exists ::gui_preferences_window_spec_test::canvasCreateCalls(.preferences.c)]} {
        error "Expected .preferences.c to create a canvas window for .preferences.c.f"
    }
    set createCall [lindex $::gui_preferences_window_spec_test::canvasCreateCalls(.preferences.c) 0]

    set inserted $::gui_preferences_window_spec_test::treeviewInserted(.preferences.options.list)
    if {[llength $inserted] != 8} {
        error "Expected 8 preference entries inserted, got [llength $inserted]"
    }

    list \
        $::gui_preferences_window_spec_test::canvasState(.preferences.c,-highlightthickness) \
        $::gui_preferences_window_spec_test::treeviewState(.preferences.options.list,-height) \
        $createCall \
        [lsort $::gui_preferences_window_spec_test::treeviewSelection(.preferences.options.list)] \
        $::gui_preferences_window_spec_test::initCalls \
        $::gui_preferences_window_spec_test::focusCalls \
        $::gui_preferences_window_spec_test::winCreateCalls
} -cleanup {
    ::gui_preferences_window_spec_test::cleanup
} -result {0 8 {window 0 0 -window .preferences.c.f -anchor nw} 0 {{chooseBoardColors .preferences.c.f.0} {::preferences::fonts .preferences.c.f.1} {ConfigToolbar .preferences.c.f.2} {::preferences::internationalization .preferences.c.f.3} {::recentFiles::configure .preferences.c.f.4} {::utils::sound::OptionsDialog .preferences.c.f.5} {::preferences::moves .preferences.c.f.6} {configInformant .preferences.c.f.7}} .preferences.options {{.preferences ConfigureScid}}}

cleanupTests
