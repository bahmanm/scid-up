package require tcltest 2.5
namespace import ::tcltest::*

set tclTestsDir [file dirname [file dirname [file dirname [info script]]]]
source [file join $tclTestsDir lib support.tcl]

namespace eval ::gui_switcher_change_icon_spec_test {
    variable stubbedCommands {}
    variable bindCalls {}

    variable treeItems
    array set treeItems {}
    variable treeConfig
    array set treeConfig {}
}

proc ::gui_switcher_change_icon_spec_test::defineTreeview {path} {
    catch {rename $path ""}
    interp alias {} $path {} ::gui_switcher_change_icon_spec_test::dispatchTreeview $path
    return $path
}

proc ::gui_switcher_change_icon_spec_test::dispatchTreeview {path subcmd args} {
    switch -- $subcmd {
        configure {
            if {[llength $args] % 2 != 0} {
                error "treeview $path configure expects option/value pairs, got: $args"
            }
            foreach {opt val} $args {
                set ::gui_switcher_change_icon_spec_test::treeConfig($path,$opt) $val
            }
            return
        }
        insert {
            # insert <parent> <index> ?options...?
            set opts [lrange $args 2 end]
            set id ""
            set image ""
            set text ""
            for {set i 0} {$i < [llength $opts]} {incr i 2} {
                set opt [lindex $opts $i]
                set val [lindex $opts [expr {$i + 1}]]
                switch -- $opt {
                    -id { set id $val }
                    -image { set image $val }
                    -text { set text $val }
                }
            }
            if {$id eq ""} { error "treeview $path insert missing -id" }
            set ::gui_switcher_change_icon_spec_test::treeItems($path,$id) [list -text $text -image $image]
            return $id
        }
        selection {
            # Return empty selection by default.
            return {}
        }
        yview { return }
        default {
            return
        }
    }
}

proc ::gui_switcher_change_icon_spec_test::setup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_change_icon_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    ::scid_test::menu_capture::install ::gui_switcher_change_icon_spec_test::stubbedCommands \
        -defaultTearoff 1 \
        -stubBind 0

    namespace eval ::windows {}
    namespace eval ::windows::switcher {}
    namespace eval ::win {}

    set ::MB3 3

    array set ::tr {
        ScidUp ScidUp
        ChangeIcon ChangeIcon
        Cancel Cancel
    }

    set ::gui_switcher_change_icon_spec_test::bindCalls {}
    array unset ::gui_switcher_change_icon_spec_test::treeItems
    array set ::gui_switcher_change_icon_spec_test::treeItems {}
    array unset ::gui_switcher_change_icon_spec_test::treeConfig
    array set ::gui_switcher_change_icon_spec_test::treeConfig {}

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands tr {tag {lang ""}} {
        if {[info exists ::tr($tag)]} { return $::tr($tag) }
        return $tag
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands sc_info {subcmd args} {
        switch -- $subcmd {
            limit {
                if {[llength $args] >= 1 && [lindex $args 0] eq "bases"} {
                    return 3
                }
                return 0
            }
            default { return "" }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands sc_base {subcmd args} {
        switch -- $subcmd {
            extra {
                # sc_base extra <baseNum>  -> return tags
                return {type 1}
            }
            default {
                error "sc_base $subcmd not stubbed in tests"
            }
        }
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands image {subcmd args} {
        if {$subcmd ne "create"} {
            error "image $subcmd not stubbed in tests"
        }
        set type [lindex $args 0]
        if {$type ne "photo"} {
            error "image create $type not stubbed in tests"
        }
        set name [lindex $args 1]
        if {$name eq "" || [string match "-*" $name]} {
            return "scid_test_image"
        }
        return $name
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands winfo {subcmd args} {
        if {$subcmd ne "exists"} {
            error "winfo $subcmd not stubbed in tests"
        }
        set w [lindex $args 0]
        expr {[llength [info commands $w]] > 0}
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands wm {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands pack {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands grid {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands update {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands focus {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands grab {args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands destroy {w} {
        catch {rename $w ""}
        return
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands bind {w sequence script} {
        lappend ::gui_switcher_change_icon_spec_test::bindCalls [list $w $sequence]
        return
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands ::win::createDialog {w} {
        if {![llength [info commands $w]]} { ::scid_test::widgets::defineWidget $w }
        return
    }

    if {![namespace exists ::ttk]} { namespace eval ::ttk {} }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands ::ttk::style {subcmd args} { return }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands ::ttk::treeview {path args} {
        ::gui_switcher_change_icon_spec_test::defineTreeview $path
        return $path
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands ::ttk::scrollbar {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands ::ttk::frame {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }

    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands dialogbutton {path args} {
        if {![llength [info commands $path]]} { ::scid_test::widgets::defineWidget $path }
        if {[llength $args]} { $path configure {*}$args }
        return $path
    }
    ::scid_test::mocks::stubCommand ::gui_switcher_change_icon_spec_test::stubbedCommands packdlgbuttons {args} { return }
}

proc ::gui_switcher_change_icon_spec_test::cleanup {} {
    ::scid_test::mocks::restoreStubs ::gui_switcher_change_icon_spec_test::stubbedCommands
    ::scid_test::widgets::reset
    ::scid_test::menu_capture::reset

    unset -nocomplain ::MB3
    unset -nocomplain ::tr
}

test gui-switcher-change-icon-dialog-spec-skeleton-1.0 {Change Icon dialog creates treeview items and binds navigation keys} -setup {
    ::gui_switcher_change_icon_spec_test::setup
} -body {
    source [file join [::scid_test::tclDir] windows switcher.tcl]

    # Keep the suite small: shrink the icon/type list used by changeBaseType.
    set ::windows::switcher::base_types {Unknown Temporary Clipbase}
    set ::numBaseTypeIcons [llength $::windows::switcher::base_types]

    changeBaseType 1

    foreach p {.btypeWin .btypeWin.t .btypeWin.yscroll .btypeWin.b .btypeWin.b.set .btypeWin.b.cancel} {
        if {![llength [info commands $p]]} {
            error "Expected widget command to exist: $p"
        }
    }

    # Treeview config and items.
    if {$::gui_switcher_change_icon_spec_test::treeConfig(.btypeWin.t,-height) ne "9"} {
        error "Expected treeview -height 9"
    }

    set items {}
    foreach id {0 1 2} {
        if {![info exists ::gui_switcher_change_icon_spec_test::treeItems(.btypeWin.t,$id)]} {
            error "Missing treeview item id $id"
        }
        set d [dict create {*}$::gui_switcher_change_icon_spec_test::treeItems(.btypeWin.t,$id)]
        lappend items [list $id [dict get $d -text] [dict get $d -image]]
    }

    # Bound sequences should include key navigation and dialog exits.
    set sequences {}
    foreach call $::gui_switcher_change_icon_spec_test::bindCalls {
        lappend sequences [lindex $call 1]
    }
    set sequences [lsort -unique $sequences]

    list $items $sequences
} -cleanup {
    ::gui_switcher_change_icon_spec_test::cleanup
} -result {{{0 { Unknown} dbt0} {1 { Temporary} dbt1} {2 { Clipbase} dbt2}} {<<TreeviewSelect>> <Down> <End> <Escape> <Home> <Return> <Up>}}

cleanupTests
